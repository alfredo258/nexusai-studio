      <circle class="dust-6" cx="700" cy="870" r="1.8"/>
      <circle class="dust-7" cx="400" cy="970" r="1.5"/>
      <circle class="dust-8" cx="800" cy="890" r="1.6"/>
      <circle class="dust-9" cx="600" cy="1000" r="1.4"/>
      <circle class="dust-10" cx="750" cy="950" r="1.5"/>
    </g>

    <ellipse cx="1320" cy="752" rx="280" ry="5" fill="rgba(0,0,0,0.06)"/>
  </svg>

  <!-- ═══════════════════════════ DARK / NIGHT ═══════════════════════════ -->
  <svg class="scene scene-dark" viewBox="0 0 1600 1100" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="skyNight" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#0a0816"/>
        <stop offset="50%" stop-color="#1a1233"/>
        <stop offset="100%" stop-color="#3b1f5c"/>
      </linearGradient>
      <linearGradient id="wallNight" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#1a1525"/>
        <stop offset="100%" stop-color="#0f0c18"/>
