    </g>

    <!-- PLANT — pot terracotta más pastel para encajar con paleta cream -->
    <g transform="translate(120, 700)">
      <path d="M -45 100 L -38 200 L 38 200 L 45 100 Z" fill="#c89b6c"/>
      <ellipse cx="0" cy="100" rx="45" ry="10" fill="#a37b50"/>
      <ellipse cx="0" cy="100" rx="40" ry="7" fill="#7a5934"/>
      <g class="plant-leaves">
        <path d="M 0 95 Q -50 30 -85 -10 Q -55 -30 -25 0 Q 5 30 0 95" fill="#86c8a8" stroke="#5fa182" stroke-width="1"/>
        <path d="M 0 95 Q 45 20 75 -25 Q 95 5 60 40 Q 25 75 0 95" fill="#9bd1b3" stroke="#6fb087" stroke-width="1"/>
        <path d="M 0 95 Q -10 10 -5 -55 Q 25 -50 18 5 Q 10 60 0 95" fill="#7ec095" stroke="#558e6e" stroke-width="1"/>
        <path d="M 0 95 Q 25 30 55 -35 Q 35 -55 8 -10 Q -2 50 0 95" fill="#a8d9c0" stroke="#7eb898" stroke-width="1"/>
        <path d="M 0 95 Q -30 30 -70 -5" stroke="#558e6e" stroke-width="0.8" fill="none" opacity="0.6"/>
        <path d="M 0 95 Q 25 25 55 -20" stroke="#558e6e" stroke-width="0.8" fill="none" opacity="0.6"/>
      </g>
    </g>

    <!-- DESK -->
    <g>
      <rect x="270" y="730" width="1330" height="22" fill="url(#deskTopDay)" stroke="#8a6e4a" stroke-width="1"/>
      <rect x="270" y="730" width="1330" height="3" fill="rgba(255,255,255,0.4)"/>
      <rect x="295" y="752" width="14" height="240" fill="url(#deskDay)"/>
      <rect x="1560" y="752" width="14" height="240" fill="url(#deskDay)"/>
