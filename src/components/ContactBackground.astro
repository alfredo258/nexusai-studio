      <circle cx="790" cy="210" r="4" fill="#d4c8ed" opacity="0.4"/>
      <circle cx="775" cy="215" r="3" fill="#d4c8ed" opacity="0.5"/>
      <g>
        <rect x="220" y="450" width="60" height="255" fill="#0d0818"/><rect x="285" y="410" width="35" height="295" fill="#150c25"/>
        <rect x="325" y="470" width="50" height="235" fill="#0d0818"/><rect x="380" y="430" width="40" height="275" fill="#150c25"/>
