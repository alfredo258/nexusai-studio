<style is:global>
/* ═══════════════════════════════════════════════════════════
   ContactBackground — "La Oficina"
   Light = día, Dark = noche. Switch via body.dark / body:not(.dark)
   ═══════════════════════════════════════════════════════════ */

.contact-bg-fixed {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}
.contact-bg-fixed svg.scene {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}

/* Light por default, dark cuando body.dark/html.dark */
.contact-bg-fixed svg.scene-dark { display: none; }
body.dark .contact-bg-fixed svg.scene-light,
html.dark .contact-bg-fixed svg.scene-light { display: none; }
body.dark .contact-bg-fixed svg.scene-dark,
html.dark .contact-bg-fixed svg.scene-dark  { display: block; }

/* ─── Animations ─── */
@keyframes lampSwing {
  0%,100% { transform: rotate(-1.2deg); }
  50%     { transform: rotate(1.2deg); }
}
@keyframes steamRise {
  0%   { opacity: 0; transform: translate(0,0) scale(0.8); }
  20%  { opacity: 0.6; }
  100% { opacity: 0; transform: translate(-6px, -40px) scale(1.4); }
}
@keyframes plantSway {
  0%,100% { transform: rotate(-0.8deg); }
  50%     { transform: rotate(0.8deg); }
}
@keyframes dustFloat {
  0%,100% { transform: translate(0,0); opacity: 0.4; }
  50%     { transform: translate(20px, -30px); opacity: 0.8; }
}
@keyframes windowShimmer {
  0%,100% { opacity: 0.95; }
  50%     { opacity: 1; }
}
@keyframes lampFlicker {
  0%,100% { opacity: 1; }
  50%     { opacity: 0.97; }
}
@keyframes carHeadlight {
  0%, 100% { opacity: 0; transform: translateX(0); }
  10%      { opacity: 1; }
  90%      { opacity: 1; }
  100%     { opacity: 0; transform: translateX(180px); }
}
@keyframes starTwinkle {
  0%, 100% { opacity: 0.4; }
  50%      { opacity: 1; }
}
@keyframes papersRustle {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-1px); }
}

/* plant-leaves sway removido — quedaba raro porque transform-origin no se anclaba bien
   a la base de las hojas, dando la sensación de que la planta saltaba.
   .plant-leaves { transform-origin: 50% 100%; animation: plantSway 9s ease-in-out infinite; } */
.window-shimmer { animation: windowShimmer 6s ease-in-out infinite; }
.lamp-glow      { animation: lampFlicker 4s ease-in-out infinite; }

.steam-1 { animation: steamRise 4s ease-in-out infinite; }
.steam-2 { animation: steamRise 4s ease-in-out -1.3s infinite; }
.steam-3 { animation: steamRise 4s ease-in-out -2.6s infinite; }

.dust-1  { animation: dustFloat 12s ease-in-out infinite; }
.dust-2  { animation: dustFloat 14s ease-in-out -3s infinite; }
.dust-3  { animation: dustFloat 16s ease-in-out -7s infinite; }
.dust-4  { animation: dustFloat 13s ease-in-out -2s infinite; }
.dust-5  { animation: dustFloat 15s ease-in-out -9s infinite; }
.dust-6  { animation: dustFloat 18s ease-in-out -5s infinite; }
.dust-7  { animation: dustFloat 11s ease-in-out -10s infinite; }
.dust-8  { animation: dustFloat 17s ease-in-out -6s infinite; }
.dust-9  { animation: dustFloat 14s ease-in-out -12s infinite; }
.dust-10 { animation: dustFloat 16s ease-in-out -8s infinite; }

.car-1 { animation: carHeadlight 11s linear infinite; }
.car-2 { animation: carHeadlight 14s linear -5s infinite; }
.car-3 { animation: carHeadlight 17s linear -10s infinite; }

.star-1 { animation: starTwinkle 4s ease-in-out infinite; }
.star-2 { animation: starTwinkle 5s ease-in-out -1s infinite; }
.star-3 { animation: starTwinkle 4.5s ease-in-out -2s infinite; }
.star-4 { animation: starTwinkle 6s ease-in-out -3s infinite; }
.star-5 { animation: starTwinkle 5.5s ease-in-out -1.5s infinite; }

.papers { animation: papersRustle 7s ease-in-out infinite; }

/* Content above */
.contact-bg-fixed ~ nav,
.contact-bg-fixed ~ main,
.contact-bg-fixed ~ footer { position: relative; z-index: 1; }

@media (prefers-reduced-motion: reduce) {
  .plant-leaves, .steam-1, .steam-2, .steam-3,
  .dust-1, .dust-2, .dust-3, .dust-4, .dust-5, .dust-6, .dust-7, .dust-8, .dust-9, .dust-10,
  .car-1, .car-2, .car-3, .star-1, .star-2, .star-3, .star-4, .star-5,
  .lamp-glow, .window-shimmer, .papers { animation: none; }
}
</style>
