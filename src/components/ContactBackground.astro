    <!-- COFFEE MUG -->
    <g transform="translate(620, 690)">
      <path d="M 0 5 L 5 50 L 55 50 L 60 5 Z" fill="#fafafc" stroke="#a78bfa" stroke-width="1.5"/>
      <path d="M 60 12 Q 80 12 80 28 Q 80 42 60 42" fill="none" stroke="#a78bfa" stroke-width="3"/>
      <ellipse cx="30" cy="6" rx="28" ry="4" fill="#5c3a1a"/>
      <ellipse cx="30" cy="5" rx="22" ry="2.5" fill="#7c4a25"/>
      <text x="22" y="35" font-family="DM Sans, sans-serif" font-size="9" font-weight="700" fill="#a78bfa">tof</text>
      <g stroke="rgba(167,139,250,0.6)" stroke-width="1.5" fill="none" stroke-linecap="round">
