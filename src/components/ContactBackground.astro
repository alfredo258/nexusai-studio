      <linearGradient id="lampCone" x1="0.5" y1="0" x2="0.5" y2="1">
        <stop offset="0%" stop-color="rgba(254, 215, 110, 0.55)"/>
        <stop offset="60%" stop-color="rgba(254, 215, 110, 0.18)"/>
        <stop offset="100%" stop-color="rgba(254, 215, 110, 0)"/>
      </linearGradient>
      <linearGradient id="glassNight" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="rgba(167,139,250,0.2)"/>
        <stop offset="50%" stop-color="rgba(167,139,250,0.05)"/>
        <stop offset="100%" stop-color="rgba(167,139,250,0)"/>
      </linearGradient>
      <radialGradient id="moonGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="rgba(231, 222, 255, 0.9)"/>
