---
// ContactBackground.astro — "La Oficina"
// Adaptación del prototipo de Claude.ai (ContactBackground Preview.html).
// Concepto: una oficina ilustrada (pared, ventana grande con vista, lámpara,
// escritorio con libros/taza/papeles, plantita, polvo flotando).
// Light = día (sol, ciudad lejana, sunbeam por la ventana, lámpara apagada).
// Dark  = noche (luna, skyline iluminado, lámpara encendida con cono de luz,
//         car headlights pasando por la calle, polvo cálido).
// La zona top-right queda libre porque ahí va el gato de TOF.
---

<div class="contact-bg-fixed" aria-hidden="true">
  <!-- ═══════════════════════════ LIGHT / DAY ═══════════════════════════ -->
  <svg class="scene scene-light" viewBox="0 0 1600 1100" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="skyDay" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#dbeafe"/>
        <stop offset="60%" stop-color="#ede9fe"/>
        <stop offset="100%" stop-color="#fef3c7"/>
      </linearGradient>
      <linearGradient id="wallDay" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#f5f1ff"/>
        <stop offset="100%" stop-color="#ede9fe"/>
      </linearGradient>
      <linearGradient id="floorDay" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#e9e2f5"/>
        <stop offset="100%" stop-color="#dbcff0"/>
      </linearGradient>
      <linearGradient id="sunbeam" x1="0" y1="0" x2="0.5" y2="1">
        <stop offset="0%" stop-color="rgba(254, 240, 138, 0.55)"/>
        <stop offset="60%" stop-color="rgba(254, 240, 138, 0.18)"/>
        <stop offset="100%" stop-color="rgba(254, 240, 138, 0)"/>
      </linearGradient>
      <linearGradient id="deskDay" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#c4a883"/>
        <stop offset="100%" stop-color="#a08561"/>
      </linearGradient>
      <linearGradient id="deskTopDay" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#d4b896"/>
        <stop offset="100%" stop-color="#b59872"/>
      </linearGradient>
      <linearGradient id="glassDay" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="rgba(255,255,255,0.4)"/>
        <stop offset="50%" stop-color="rgba(255,255,255,0.1)"/>
        <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
      </linearGradient>
      <radialGradient id="sunGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="rgba(254, 240, 138, 0.9)"/>
        <stop offset="100%" stop-color="rgba(254, 240, 138, 0)"/>
      </radialGradient>
    </defs>

    <rect x="0" y="0" width="1600" height="700" fill="url(#skyDay)"/>
    <rect x="0" y="0" width="1600" height="900" fill="url(#wallDay)"/>
    <polygon points="0,900 1600,900 1600,1100 0,1100" fill="url(#floorDay)"/>
    <g stroke="rgba(109,40,217,0.06)" stroke-width="0.7">
      <line x1="0" y1="930" x2="1600" y2="950"/>
      <line x1="0" y1="970" x2="1600" y2="990"/>
      <line x1="0" y1="1010" x2="1600" y2="1030"/>
      <line x1="0" y1="1050" x2="1600" y2="1070"/>
    </g>

    <!-- WINDOW -->
    <g class="window">
      <rect x="180" y="80" width="780" height="640" rx="8" fill="#e8dff5" stroke="#7c6ba0" stroke-width="2"/>
      <rect x="195" y="95" width="750" height="610" rx="4" fill="url(#skyDay)"/>
      <!-- Sun glow + rays + core -->
      <circle cx="780" cy="220" r="80" fill="url(#sunGlow)" opacity="0.7"/>
      <g stroke="rgba(254, 240, 138, 0.45)" stroke-width="1.5" stroke-linecap="round" class="window-shimmer">
        <line x1="780" y1="135" x2="780" y2="155"/>
        <line x1="780" y1="285" x2="780" y2="305"/>
        <line x1="695" y1="220" x2="715" y2="220"/>
        <line x1="845" y1="220" x2="865" y2="220"/>
        <line x1="720" y1="160" x2="734" y2="174"/>
        <line x1="826" y1="266" x2="840" y2="280"/>
        <line x1="720" y1="280" x2="734" y2="266"/>
        <line x1="826" y1="174" x2="840" y2="160"/>
      </g>
      <circle cx="780" cy="220" r="55" fill="url(#sunGlow)"/>
      <circle cx="780" cy="220" r="32" fill="#fef9c3"/>
      <circle cx="772" cy="212" r="8" fill="rgba(255,255,255,0.55)"/>
      <g fill="#c4b5fd" opacity="0.55">
        <rect x="220" y="450" width="60" height="255"/><rect x="285" y="410" width="35" height="295"/>
        <rect x="325" y="470" width="50" height="235"/><rect x="380" y="430" width="40" height="275"/>
        <rect x="425" y="490" width="55" height="215"/><rect x="485" y="440" width="38" height="265"/>
        <rect x="528" y="475" width="45" height="230"/><rect x="578" y="455" width="55" height="250"/>
        <rect x="638" y="490" width="42" height="215"/><rect x="685" y="465" width="50" height="240"/>
        <rect x="740" y="450" width="38" height="255"/><rect x="783" y="495" width="48" height="210"/>
        <rect x="836" y="430" width="55" height="275"/><rect x="896" y="475" width="44" height="230"/>
      </g>
      <g fill="rgba(255,255,255,0.85)">
        <ellipse cx="380" cy="230" rx="55" ry="18"/>
        <ellipse cx="410" cy="220" rx="40" ry="16"/>
        <ellipse cx="350" cy="225" rx="35" ry="14"/>
      </g>
      <g fill="rgba(255,255,255,0.75)">
        <ellipse cx="620" cy="320" rx="45" ry="14"/>
        <ellipse cx="640" cy="312" rx="32" ry="12"/>
      </g>
      <line x1="585" y1="95" x2="585" y2="705" stroke="#7c6ba0" stroke-width="3"/>
      <line x1="195" y1="395" x2="945" y2="395" stroke="#7c6ba0" stroke-width="3"/>
      <rect x="195" y="95" width="750" height="610" fill="url(#glassDay)" class="window-shimmer"/>
      <rect x="170" y="715" width="800" height="14" rx="3" fill="#a89bc7"/>
      <rect x="175" y="729" width="790" height="6" fill="rgba(109,40,217,0.18)"/>
    </g>

    <polygon class="window-shimmer" fill="url(#sunbeam)" points="280,720 880,720 1100,1100 60,1100"/>

    <!-- PICTURE FRAME — mini chart (mes a mes de reuniones agendadas) -->
    <g>
      <rect x="40" y="180" width="100" height="130" fill="#fef3c7" stroke="#a08561" stroke-width="3"/>
      <rect x="50" y="190" width="80" height="110" fill="#fafafc"/>
      <!-- Title bar -->
      <rect x="55" y="195" width="40" height="3" fill="#6d28d9" opacity="0.5"/>
      <rect x="55" y="201" width="25" height="2" fill="#a78bfa" opacity="0.4"/>
      <!-- Bar chart growing -->
      <rect x="58" y="280" width="8" height="10" fill="#a78bfa"/>
      <rect x="70" y="270" width="8" height="20" fill="#a78bfa"/>
      <rect x="82" y="255" width="8" height="35" fill="#8b5cf6"/>
      <rect x="94" y="240" width="8" height="50" fill="#7c3aed"/>
      <rect x="106" y="220" width="8" height="70" fill="#6d28d9"/>
      <rect x="118" y="210" width="8" height="80" fill="#5b21b6"/>
      <!-- Axis -->
