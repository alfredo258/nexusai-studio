    <!-- PAPERS -->
    <g class="papers" transform="translate(770, 705)">
      <rect x="0" y="20" width="100" height="22" fill="#fff" stroke="rgba(109,40,217,0.2)" stroke-width="0.5" transform="rotate(-2)"/>
      <rect x="3" y="13" width="100" height="22" fill="#fff" stroke="rgba(109,40,217,0.2)" stroke-width="0.5" transform="rotate(1)"/>
      <rect x="2" y="6" width="100" height="22" fill="#fff" stroke="rgba(109,40,217,0.25)" stroke-width="0.5"/>
      <line x1="12" y1="14" x2="80" y2="14" stroke="#a78bfa" stroke-width="1"/>
      <line x1="12" y1="20" x2="65" y2="20" stroke="rgba(109,40,217,0.4)" stroke-width="0.6"/>
      <line x1="12" y1="25" x2="75" y2="25" stroke="rgba(109,40,217,0.4)" stroke-width="0.6"/>
    </g>

    <!-- PENCIL -->
    <g transform="translate(910, 720)">
      <rect x="0" y="0" width="80" height="5" fill="#fbbf24"/>
      <polygon points="80,0 88,2.5 80,5" fill="#1f2937"/>
      <rect x="-8" y="0" width="8" height="5" fill="#dc2626"/>
      <rect x="-12" y="0" width="4" height="5" fill="#9ca3af"/>
    </g>

    <!-- LAMP (off in day) — sway sutil en el brazo articulado -->
    <g transform="translate(1080, 580)">
      <!-- Base anclada al desk (no sway) -->
      <ellipse cx="0" cy="148" rx="38" ry="6" fill="#7c3aed"/>
      <rect x="-28" y="138" width="56" height="12" rx="2" fill="#8b5cf6"/>
      <circle cx="0" cy="138" r="5" fill="#7c3aed"/>
      <!-- Brazo + cabeza (sway sutil simulando peso del shade) -->
      <g class="lamp-cord-group" style="transform-origin: 0px 138px;">
        <line x1="0" y1="138" x2="-30" y2="60" stroke="#8b5cf6" stroke-width="6" stroke-linecap="round"/>
        <line x1="-30" y1="60" x2="20" y2="20" stroke="#8b5cf6" stroke-width="6" stroke-linecap="round"/>
        <circle cx="-30" cy="60" r="5" fill="#7c3aed"/>
        <path d="M 5 0 L 50 5 L 45 35 L 0 30 Z" fill="#a78bfa" stroke="#7c3aed" stroke-width="1.5"/>
        <ellipse cx="22" cy="32" rx="22" ry="3" fill="#7c3aed"/>
        <ellipse cx="22" cy="32" rx="18" ry="2" fill="rgba(254, 240, 138, 0.15)"/>
      </g>
    </g>

    <!-- DUST -->
    <g fill="rgba(254, 240, 138, 0.7)">
      <circle class="dust-1" cx="350" cy="850" r="2"/>
      <circle class="dust-2" cx="450" cy="780" r="1.5"/>
