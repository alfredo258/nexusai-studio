      <rect x="0" y="0" width="6" height="14" fill="#fde68a"/>
      <rect x="-3" y="14" width="125" height="12" fill="#fef3c7" stroke="#d6b85a" stroke-width="0.5"/>
      <rect x="-3" y="14" width="6" height="12" fill="#a78bfa"/>
      <rect x="2" y="26" width="118" height="10" fill="#a78bfa" stroke="#7c3aed" stroke-width="0.5"/>
      <rect x="2" y="26" width="5" height="10" fill="#fbbf24"/>
