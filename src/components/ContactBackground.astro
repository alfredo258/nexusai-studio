          <rect x="465" y="540" width="5" height="7"/><rect x="495" y="475" width="4" height="6"/>
          <rect x="510" y="495" width="4" height="6"/><rect x="540" y="500" width="5" height="7"/>
          <rect x="555" y="525" width="5" height="7"/><rect x="590" y="475" width="5" height="7"/>
          <rect x="610" y="500" width="5" height="7"/><rect x="600" y="535" width="5" height="7"/>
