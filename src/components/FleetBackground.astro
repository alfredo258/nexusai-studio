  };

  // ═══ SPAWN FLEET ═══
  const fleetSpec = [
    { cls: 's-capital', svg: shipSVGs.capital },
    { cls: 's-lead',    svg: shipSVGs.saucer  },
    { cls: 's-wing1',   svg: shipSVGs.saucer  },
    { cls: 's-wing2',   svg: shipSVGs.saucer  },
    { cls: 's-scout-r', svg: shipSVGs.drone   },
    { cls: 's-scout-l', svg: shipSVGs.drone   },
    { cls: 's-diag',    svg: shipSVGs.saucer  },
  ];
  const fleetEl = document.getElementById('fleet');
  fleetSpec.forEach(function(s) {
    const el = document.createElement('div');
    el.className = 'ship ' + s.cls;
    el.innerHTML = s.svg;
    fleetEl.appendChild(el);
  });

  // ═══ CURSOR HALO — naves cercanas brillan más ═══
  const ships = Array.prototype.slice.call(document.querySelectorAll('.ship'));
  const RADIUS = 260;
  let pendingHover = false, lastX = 0, lastY = 0;
  function applyHover() {
    pendingHover = false;
    ships.forEach(function(s) {
      const rect = s.getBoundingClientRect();
      if (rect.width === 0) return;
      const sx = rect.left + rect.width / 2;
      const sy = rect.top  + rect.height / 2;
      const d = Math.hypot(sx - lastX, sy - lastY);
      if (d < RADIUS) {
        const t = 1 - d / RADIUS;
        s.style.filter =
          'drop-shadow(0 0 ' + (14 + t * 32) + 'px rgba(196,181,253,' + (0.7 + t * 0.55) + ')) ' +
          'drop-shadow(0 0 ' + (5 + t * 12) + 'px rgba(255,255,255,' + (0.4 + t * 0.45) + ')) ' +
          'brightness(' + (1.15 + t * 0.5) + ')';
      } else if (s.style.filter) {
        s.style.filter = '';
      }
    });
  }
  document.addEventListener('pointermove', function(e) {
    lastX = e.clientX; lastY = e.clientY;
    if (!pendingHover) {
      pendingHover = true;
      requestAnimationFrame(applyHover);
    }
  });
  document.addEventListener('pointerleave', function() {
    ships.forEach(function(s) { s.style.filter = ''; });
  });
})();
</script>
