stroke="rgba(255,255,255,0.25)" stroke-width="0.5"/><line x1="-26" y1="2" x2="26" y2="2" stroke="rgba(15,4,32,0.6)" stroke-width="0.5"/><line x1="-12" y1="-5" x2="-12" y2="6" stroke="rgba(15,4,32,0.4)" stroke-width="0.35"/><line x1="12" y1="-5" x2="12" y2="6" stroke="rgba(15,4,32,0.4)" stroke-width="0.35"/><ellipse cx="0" cy="-4" rx="13" ry="6" fill="url(#sc-dome)"/><ellipse cx="-4" cy="-7" rx="5" ry="1.8" fill="rgba(255,255,255,0.85)"/><ellipse cx="5" cy="-4" rx="1.5" ry="3.5" fill="rgba(255,255,255,0.25)"/><line x1="0" y1="-10" x2="0" y2="-17" stroke="rgba(196,181,253,0.85)" stroke-width="0.7"/><circle cx="0" cy="-18" r="1.3" fill="#fde68a"/><circle cx="0" cy="-18" r="3" fill="rgba(253,230,138,0.45)"/><circle cx="-22" cy="-2" r="0.6" fill="rgba(196,181,253,0.9)"/><circle cx="22" cy="-2" r="0.6" fill="rgba(196,181,253,0.9)"/><circle class="ship-light" cx="-17" cy="4.5" r="1.5" fill="#fbbf24"/><circle class="ship-light l2" cx="0" cy="5" r="1.5" fill="#fbbf24"/><circle class="ship-light l3" cx="17" cy="4.5" r="1.5" fill="#fbbf24"/><circle cx="36" cy="0" r="7" fill="rgba(255,255,255,0.35)"/><circle cx="36" cy="0" r="2" fill="#fffafe"/></svg>',
