---
// FleetBackground.astro — "Outbound Fleet"
// Adaptación del prototipo de Claude.ai (handoff: design_handoff_faq_background).
// Concepto: cielo profundo con flota de naves espaciales, nebulosas, estrellas
// con parallax, shooting stars. Dark-only por diseño (la metáfora "outbound = naves
// saliendo hacia afuera" se rompe en light mode).
//
// Estructura:
//   .stage (position: fixed; z-index: 0)
//     ├─ .sky          → gradiente cósmico de fondo
//     ├─ .neb × 4      → nebulosas con drift animado
//     ├─ .stars × 3    → canvases de estrellas con parallax al cursor
//     ├─ .twinkle      → 28 estrellas con twinkle CSS
//     ├─ .shooter × 3  → estrellas fugaces con timings escalonados
//     ├─ .fleet        → 7 naves SVG (capital + 3 saucers + 2 drones + diag)
//     ├─ .grain        → ruido sutil
//     └─ .vignette     → viñeta radial
//
// Interacciones (en script):
//   - Stars: drawn on canvas at mount + resize. 380/180/80 stars across 3 layers.
//   - Twinkle: 28 dots inserted as <b> elements with random positions/delays.
//   - Parallax: pointermove → translate3d on each .stars layer (rAF throttled).
//   - Cursor halo: ships within 260px of cursor get boosted drop-shadow.
//   - prefers-reduced-motion: animations off.
//   - Mobile (≤640px): wing1, wing2, scout-l, diag are hidden.
---

<div class="stage" aria-hidden="true">
  <div class="sky"></div>

  <div class="neb neb-1"></div>
  <div class="neb neb-2"></div>
  <div class="neb neb-3"></div>
  <div class="neb neb-4"></div>

  <div class="stars" data-mult="0.25"><canvas id="starsFar"></canvas></div>
  <div class="stars" data-mult="0.6"><canvas id="starsMid"></canvas></div>
  <div class="stars" data-mult="1.2"><canvas id="starsNear"></canvas></div>

  <div class="twinkle" id="twinkle"></div>

  <div class="shooter sh-1"></div>
  <div class="shooter sh-2"></div>
  <div class="shooter sh-3"></div>

  <div class="fleet" id="fleet"></div>

  <div class="grain"></div>
  <div class="vignette"></div>
</div>

<style is:global>
/* ═══════════════════════════════════════════════════════════
   FleetBackground — "Outbound Fleet"
   Self-contained, dark-only, mobile-aware, reduced-motion safe.
   ═══════════════════════════════════════════════════════════ */

.stage {
  position: fixed; inset: 0; z-index: 0;
  overflow: hidden; pointer-events: none;
  isolation: isolate;
}

/* base sky — multi-layer cosmic gradient */
.sky {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 20% 12%, rgba(91,33,182,0.55), transparent 60%),
    radial-gradient(ellipse 70% 60% at 82% 78%, rgba(67,20,140,0.50), transparent 65%),
    radial-gradient(ellipse 60% 80% at 50% 100%, rgba(37,9,82,0.65), transparent 70%),
    linear-gradient(180deg, #08051a 0%, #04030a 50%, #02010a 100%);
}

/* ─── nebulae ─── */
.neb {
  position: absolute; border-radius: 50%;
  filter: blur(80px); mix-blend-mode: screen;
  will-change: transform; opacity: 0.9;
}
.neb-1 { width: 55vw; height: 55vw; left: -15vw; top: -12vh;
  background: radial-gradient(circle, rgba(167,139,250,0.55), transparent 65%);
  animation: drift1 80s ease-in-out infinite; }
.neb-2 { width: 65vw; height: 65vw; right: -20vw; top: 35vh;
  background: radial-gradient(circle, rgba(124,58,237,0.50), transparent 65%);
  animation: drift2 100s ease-in-out infinite; }
.neb-3 { width: 50vw; height: 50vw; left: 25vw; bottom: -25vh;
  background: radial-gradient(circle, rgba(196,181,253,0.42), transparent 65%);
  animation: drift3 90s ease-in-out infinite; }
.neb-4 { width: 35vw; height: 35vw; right: 8vw; top: 5vh;
  background: radial-gradient(circle, rgba(251,191,36,0.18), transparent 65%);
  animation: drift4 120s ease-in-out infinite; }
@keyframes drift1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(8vw,7vh) scale(1.10)} }
@keyframes drift2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-10vw,-5vh) scale(0.92)} }
@keyframes drift3 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(7vw,-9vh) scale(1.08)} }
@keyframes drift4 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-6vw,4vh) scale(0.95)} }

/* ─── star canvases (3 parallax layers) ─── */
.stars {
  position: absolute; inset: 0;
  transform: translate3d(var(--px,0px), var(--py,0px), 0);
  will-change: transform;
  transition: transform 900ms cubic-bezier(0.16, 1, 0.3, 1);
}
.stars canvas { width: 100%; height: 100%; display: block; }

/* ─── twinkle subset (CSS-animated stars) ─── */
.twinkle { position: absolute; inset: 0; pointer-events: none; }
.twinkle b {
  position: absolute;
  width: 2px; height: 2px; border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 6px 2px rgba(196,181,253,0.85);
  animation: twk 4s ease-in-out infinite;
}
.twinkle b.big {
  width: 3px; height: 3px;
  box-shadow: 0 0 10px 3px rgba(255,255,255,0.95), 0 0 16px 4px rgba(196,181,253,0.6);
}
@keyframes twk {
  0%,100% { opacity: 0.35; transform: scale(1); }
  50%     { opacity: 1;    transform: scale(1.45); }
}

/* ─── shooting stars ─── */
.shooter {
  position: absolute; left: 0; top: 0;
  width: 280px; height: 1.5px;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(196,181,253,0.0) 35%,
    rgba(196,181,253,0.85) 88%,
    rgba(255,255,255,1) 100%);
  transform-origin: 100% 50%;
  will-change: transform, opacity; opacity: 0;
}
.shooter::after {
  content: ""; position: absolute; right: -3px; top: -2.5px;
  width: 6px; height: 6px; border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 14px 5px rgba(196,181,253,0.95);
}
.sh-1 { animation: shoot1 13s ease-in 4s infinite; }
.sh-2 { animation: shoot2 17s ease-in 9s infinite; }
.sh-3 { animation: shoot3 21s ease-in 14s infinite; }
@keyframes shoot1 {
  0%   { transform: translate(-200px, 8vh) rotate(20deg) scaleX(0); opacity: 0; }
  1%   { opacity: 1; transform: translate(-200px, 8vh) rotate(20deg) scaleX(0.15); }
  11%  { transform: translate(70vw, 38vh) rotate(20deg) scaleX(1); opacity: 0; }
  100% { opacity: 0; }
}
@keyframes shoot2 {
  0%   { transform: translate(45vw, -12vh) rotate(58deg) scaleX(0); opacity: 0; }
  1%   { opacity: 1; transform: translate(45vw, -12vh) rotate(58deg) scaleX(0.15); }
  12%  { transform: translate(85vw, 60vh) rotate(58deg) scaleX(1); opacity: 0; }
  100% { opacity: 0; }
}
@keyframes shoot3 {
  0%   { transform: translate(calc(100vw + 60px), 25vh) rotate(160deg) scaleX(0); opacity: 0; }
  1%   { opacity: 1; transform: translate(calc(100vw + 60px), 25vh) rotate(160deg) scaleX(0.15); }
  13%  { transform: translate(15vw, 70vh) rotate(160deg) scaleX(1); opacity: 0; }
  100% { opacity: 0; }
}

/* ─── fleet ─── */
.fleet { position: absolute; inset: 0; pointer-events: none; }

.ship {
  position: absolute; left: 0; top: 0;
  will-change: transform, filter;
  transform-origin: center;
  filter: drop-shadow(0 0 12px rgba(167,139,250,0.55))
          drop-shadow(0 0 4px rgba(255,255,255,0.25));
  transition: filter 280ms ease;
}
.ship.s-capital {
  filter: drop-shadow(0 0 22px rgba(251,191,36,0.55))
          drop-shadow(0 0 8px rgba(255,255,255,0.35));
}
.ship.s-lead, .ship.s-wing1, .ship.s-wing2 {
  filter: drop-shadow(0 0 18px rgba(167,139,250,0.75))
          drop-shadow(0 0 6px rgba(255,255,255,0.35));
}
.ship.s-scout-r {
  filter: drop-shadow(0 0 18px rgba(34,211,238,0.80))
          drop-shadow(0 0 6px rgba(255,255,255,0.40));
}
.ship.s-scout-l {
  filter: drop-shadow(0 0 18px rgba(244,114,182,0.75))
          drop-shadow(0 0 6px rgba(255,255,255,0.40));
}
.ship.s-diag {
  filter: drop-shadow(0 0 18px rgba(196,181,253,0.80))
          drop-shadow(0 0 6px rgba(255,255,255,0.40));
}
.ship svg { display: block; overflow: visible; }
.ship .trail { filter: blur(0.8px); }

.ship-light    { animation: blink 1.7s ease-in-out infinite; }
.ship-light.l2 { animation-delay: 0.4s; }
.ship-light.l3 { animation-delay: 0.85s; }
@keyframes blink { 0%,100%{opacity:0.4} 50%{opacity:1} }

.engine-core { animation: enginePulse 1.4s ease-in-out infinite; transform-origin: center; }
@keyframes enginePulse {
  0%,100% { opacity: 0.85; transform: scale(1); }
  50%     { opacity: 1;    transform: scale(1.12); }
}

/* ─── trajectories ─── */
.ship.s-capital {
  animation: pathCapital 75s cubic-bezier(0.4,0,0.6,1) infinite;
  animation-delay: -8s;
}
@keyframes pathCapital {
  0%   { transform: translate(-380px, 48vh) rotate(-1deg); }
  25%  { transform: translate(22vw, 51vh) rotate(0deg); }
  50%  { transform: translate(50vw, 49vh) rotate(1deg); }
  75%  { transform: translate(78vw, 52vh) rotate(0deg); }
  100% { transform: translate(calc(100vw + 400px), 50vh) rotate(-1deg); }
}

.ship.s-lead {
  animation: pathLead 36s cubic-bezier(0.4,0,0.6,1) infinite;
  animation-delay: -2s;
}
@keyframes pathLead {
  0%   { transform: translate(calc(100vw + 200px), 6vh) rotate(-3deg) scaleX(-1); }
  25%  { transform: translate(74vw, 4vh) rotate(-4deg) scaleX(-1); }
  50%  { transform: translate(50vw, 8vh) rotate(0deg) scaleX(-1); }
  75%  { transform: translate(26vw, 5vh) rotate(2deg) scaleX(-1); }
  100% { transform: translate(-220px, 7vh) rotate(-3deg) scaleX(-1); }
}
.ship.s-wing1 {
  animation: pathWing1 36s cubic-bezier(0.4,0,0.6,1) infinite;
  animation-delay: -3.4s;
}
@keyframes pathWing1 {
  0%   { transform: translate(calc(100vw + 240px), 11vh) rotate(-3deg) scaleX(-0.78) scaleY(0.78); }
  25%  { transform: translate(76vw, 9vh) rotate(-4deg) scaleX(-0.78) scaleY(0.78); }
  50%  { transform: translate(52vw, 13vh) rotate(0deg) scaleX(-0.78) scaleY(0.78); }
  75%  { transform: translate(28vw, 10vh) rotate(2deg) scaleX(-0.78) scaleY(0.78); }
  100% { transform: translate(-260px, 12vh) rotate(-3deg) scaleX(-0.78) scaleY(0.78); }
}
.ship.s-wing2 {
  animation: pathWing2 36s cubic-bezier(0.4,0,0.6,1) infinite;
  animation-delay: -4.6s;
}
@keyframes pathWing2 {
  0%   { transform: translate(calc(100vw + 280px), 2vh) rotate(-3deg) scaleX(-0.78) scaleY(0.78); }
  25%  { transform: translate(78vw, 0vh) rotate(-4deg) scaleX(-0.78) scaleY(0.78); }
  50%  { transform: translate(54vw, 3vh) rotate(0deg) scaleX(-0.78) scaleY(0.78); }
  75%  { transform: translate(30vw, 1vh) rotate(2deg) scaleX(-0.78) scaleY(0.78); }
  100% { transform: translate(-300px, 2vh) rotate(-3deg) scaleX(-0.78) scaleY(0.78); }
}

.ship.s-scout-r { animation: pathScoutR 22s linear infinite; }
@keyframes pathScoutR {
  0%   { transform: translate(94vw, -120px) rotate(95deg) scale(0.55); opacity: 0; }
  8%   { opacity: 1; }
  50%  { transform: translate(96vw, 50vh) rotate(95deg) scale(0.58); }
  92%  { opacity: 1; }
  100% { transform: translate(94vw, calc(100vh + 120px)) rotate(95deg) scale(0.55); opacity: 0; }
}
.ship.s-scout-l {
  animation: pathScoutL 28s linear infinite;
  animation-delay: -10s;
}
@keyframes pathScoutL {
  0%   { transform: translate(4vw, calc(100vh + 120px)) rotate(-85deg) scale(0.55); opacity: 0; }
  8%   { opacity: 1; }
  50%  { transform: translate(6vw, 50vh) rotate(-85deg) scale(0.58); }
  92%  { opacity: 1; }
  100% { transform: translate(4vw, -120px) rotate(-85deg) scale(0.55); opacity: 0; }
}

.ship.s-diag {
  animation: pathDiag 44s cubic-bezier(0.4,0,0.6,1) infinite;
  animation-delay: -12s;
}
@keyframes pathDiag {
  0%   { transform: translate(-200px, -100px) rotate(45deg) scale(0.65); }
  50%  { transform: translate(50vw, 50vh) rotate(45deg) scale(0.65); opacity: 0.9; }
  100% { transform: translate(calc(100vw + 200px), calc(100vh + 100px)) rotate(45deg) scale(0.65); }
}

/* ─── grain + vignette ─── */
.grain {
  position: absolute; inset: -10%; pointer-events: none;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' seed='9'/><feColorMatrix values='0 0 0 0 0.55 0 0 0 0 0.45 0 0 0 0 0.75 0 0 0 1 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  opacity: 0.07; mix-blend-mode: overlay;
}
.vignette {
  position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(ellipse 70% 60% at 50% 50%, transparent 30%, rgba(4,3,10,0.55) 80%, rgba(4,3,10,0.96) 100%);
}

/* Content above the stage */
.stage ~ nav,
.stage ~ main,
.stage ~ footer { position: relative; z-index: 1; }

@media (prefers-reduced-motion: reduce) {
  .neb, .ship, .shooter, .twinkle b { animation: none !important; }
  .stars { transition: none !important; }
}
@media (max-width: 640px) {
  .ship.s-wing1, .ship.s-wing2, .ship.s-scout-l, .ship.s-diag { display: none; }
}

/* ═══════════════════════════════════════════════════════════
   LIGHT MODE TWILIGHT — solo cuando body tiene .faq-light
   El dark default NUNCA se ve afectado por estas reglas.
   ═══════════════════════════════════════════════════════════ */
body.faq-light .sky {
  background:
    radial-gradient(ellipse 80% 60% at 20% 12%, rgba(196,181,253,0.55), transparent 60%),
    radial-gradient(ellipse 70% 60% at 82% 78%, rgba(244,114,182,0.30), transparent 65%),
    radial-gradient(ellipse 60% 80% at 50% 100%, rgba(253,230,138,0.35), transparent 70%),
    linear-gradient(180deg, #ddd6fe 0%, #f5e6f5 50%, #fef3c7 100%) !important;
}
body.faq-light .neb-1 {
  background: radial-gradient(circle, rgba(167,139,250,0.45), transparent 65%);
  opacity: 0.7;
}
body.faq-light .neb-2 {
  background: radial-gradient(circle, rgba(244,114,182,0.35), transparent 65%);
  opacity: 0.6;
}
body.faq-light .neb-3 {
  background: radial-gradient(circle, rgba(196,181,253,0.42), transparent 65%);
  opacity: 0.7;
}
body.faq-light .neb-4 {
  background: radial-gradient(circle, rgba(251,191,36,0.30), transparent 65%);
  opacity: 0.5;
}
body.faq-light .stars { display: none; }
body.faq-light .twinkle b {
  background: rgba(109,40,217,0.55);
  box-shadow: 0 0 6px 2px rgba(167,139,250,0.45);
}
body.faq-light .shooter { display: none; }
body.faq-light .vignette {
  background: radial-gradient(ellipse 70% 60% at 50% 50%, transparent 30%, rgba(124,58,237,0.10) 80%, rgba(124,58,237,0.20) 100%);
}
body.faq-light .grain { opacity: 0.04; mix-blend-mode: multiply; }
body.faq-light .ship.s-capital {
  filter: drop-shadow(0 0 24px rgba(251,191,36,0.65))
          drop-shadow(0 4px 12px rgba(91,33,182,0.40));
}
body.faq-light .ship.s-lead,
body.faq-light .ship.s-wing1,
body.faq-light .ship.s-wing2 {
  filter: drop-shadow(0 0 18px rgba(124,58,237,0.65))
          drop-shadow(0 4px 10px rgba(91,33,182,0.40));
}
body.faq-light .ship.s-scout-r {
  filter: drop-shadow(0 0 18px rgba(34,211,238,0.70))
          drop-shadow(0 4px 10px rgba(91,33,182,0.40));
}
body.faq-light .ship.s-scout-l {
  filter: drop-shadow(0 0 18px rgba(244,114,182,0.65))
          drop-shadow(0 4px 10px rgba(91,33,182,0.40));
}
body.faq-light .ship.s-diag {
  filter: drop-shadow(0 0 18px rgba(167,139,250,0.70))
          drop-shadow(0 4px 10px rgba(91,33,182,0.40));
}
</style>

<script is:inline>
(function() {
  // ═══ STAR FIELD — 3 capas con parallax suave al cursor ═══
  function drawStars(canvas, count, sizeRange, opacityRange) {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const w = canvas.parentElement.clientWidth;
    const h = canvas.parentElement.clientHeight;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    const ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    for (let i = 0; i < count; i++) {
      const x = Math.random() * w;
      const y = Math.random() * h;
      const r = sizeRange[0] + Math.random() * (sizeRange[1] - sizeRange[0]);
      const op = opacityRange[0] + Math.random() * (opacityRange[1] - opacityRange[0]);

      ctx.beginPath();
      ctx.arc(x, y, r * 3.5, 0, Math.PI * 2);
      const grad = ctx.createRadialGradient(x, y, 0, x, y, r * 3.5);
      grad.addColorStop(0, 'rgba(196,181,253,' + (op * 0.45) + ')');
      grad.addColorStop(1, 'rgba(196,181,253,0)');
      ctx.fillStyle = grad;
      ctx.fill();

      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,' + op + ')';
      ctx.fill();
    }
  }

  const canvases = {
    far:  document.getElementById('starsFar'),
    mid:  document.getElementById('starsMid'),
    near: document.getElementById('starsNear'),
  };
  if (!canvases.far || !canvases.mid || !canvases.near) return;

  function redrawStars() {
    drawStars(canvases.far,  380, [0.4, 0.9],  [0.20, 0.55]);
    drawStars(canvases.mid,  180, [0.6, 1.3],  [0.40, 0.80]);
    drawStars(canvases.near,  80, [1.0, 1.9],  [0.65, 1.0]);
  }
  redrawStars();
  let resizeT;
  window.addEventListener('resize', function() {
    clearTimeout(resizeT);
    resizeT = setTimeout(redrawStars, 200);
  });

  // ═══ TWINKLE STARS (CSS-animated subset) ═══
  const tw = document.getElementById('twinkle');
  const TWINKLES = 28;
  for (let i = 0; i < TWINKLES; i++) {
    const b = document.createElement('b');
    if (Math.random() < 0.25) b.classList.add('big');
    b.style.left = (Math.random() * 100) + '%';
    b.style.top  = (Math.random() * 100) + '%';
    b.style.animationDelay = (-Math.random() * 4) + 's';
    b.style.animationDuration = (3 + Math.random() * 4) + 's';
    tw.appendChild(b);
  }

  // ═══ PARALLAX (rAF-throttled) ═══
  let mxN = 0, myN = 0, parallaxQueued = false;
  const starLayers = Array.prototype.slice.call(document.querySelectorAll('.stars'));
  function applyParallax() {
    parallaxQueued = false;
    starLayers.forEach(function(layer) {
      const mult = parseFloat(layer.dataset.mult);
      layer.style.setProperty('--px', (-mxN * 36 * mult) + 'px');
      layer.style.setProperty('--py', (-myN * 22 * mult) + 'px');
    });
  }
  document.addEventListener('pointermove', function(e) {
    mxN = (e.clientX / window.innerWidth - 0.5);
    myN = (e.clientY / window.innerHeight - 0.5);
    if (!parallaxQueued) {
      parallaxQueued = true;
      requestAnimationFrame(applyParallax);
    }
  });

  // ═══ SHIP SVGs ═══
  const shipSVGs = {
