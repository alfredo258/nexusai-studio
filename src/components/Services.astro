---
import JsonLd from './JsonLd.astro';

const services = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    title: 'Agentes IA Autónomos',
    description: 'Libera a tu equipo de tareas repetitivas. Agentes que atienden clientes, analizan datos y ejecutan acciones 24/7 — sin supervisión.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>`,
    title: 'Webs Inteligentes',
    description: 'Webs que convierten y que los buscadores de IA recomiendan. Lighthouse 100, diseño premium y optimizadas para GSO/AEO.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    title: 'Automatización de Procesos',
    description: 'Conectamos tus herramientas existentes con flujos de IA que eliminan trabajo manual y reducen errores un 95%.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
    title: 'Consultoría Estratégica IA',
    description: 'Sabes exactamente dónde invertir en IA. Recibe un roadmap con las oportunidades de mayor ROI para tu operación.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>`,
    title: 'Chatbots & Asistentes',
    description: 'Chatbots que realmente entienden a tus clientes. Resuelven el 60% de consultas sin intervención humana, integrados con tus sistemas.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    title: 'RAG & Knowledge Bases',
    description: 'Tu equipo encuentra cualquier dato en segundos. Una pregunta en lenguaje natural, una respuesta precisa desde toda tu documentación.',
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "provider": {
    "@type": "Organization",
    "name": "NexusAI Studio"
  },
  "serviceType": "Artificial Intelligence Consulting",
  "areaServed": "Global",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de IA",
    "itemListElement": services.map((s, i) => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": s.title,
        "description": s.description
      }
    }))
  }
};
---

<section id="servicios" class="py-24 md:py-32 relative">
  <JsonLd data={serviceSchema} />

  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="text-violet-400 text-sm font-medium tracking-wider uppercase">Servicios</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">
        Soluciones de IA que
        <span class="text-violet-400">Generan Impacto</span>
      </h2>
      <p class="mt-4 text-neutral-400 max-w-2xl mx-auto text-lg">
        No vendemos tecnología por vender. Cada proyecto se diseña para resolver un problema real y generar retorno medible.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <article class="group p-6 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.05] hover:border-violet-500/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center text-violet-400 mb-4 group-hover:bg-violet-500/20 transition-colors">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-lg font-semibold mb-2">{service.title}</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{service.description}</p>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="#contacto" class="inline-flex items-center gap-2 text-violet-400 hover:text-violet-300 font-medium transition-colors">
        ¿Qué servicio encaja con tu caso? Agenda 15 min y te lo decimos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
