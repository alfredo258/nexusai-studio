---
/**
 * Spider-web network background — extends the Hero's web visual
 * into this section for visual continuity.
 * Generated at build time, no JS needed.
 */
function generateWebSvg(): string {
  const w = 1200;
  const h = 900;
  const lines: string[] = [];

  // Create anchor nodes scattered across the section
  const nodes: {x: number; y: number}[] = [];
  // Edge anchors
  for (let i = 0; i <= 10; i++) {
    nodes.push({ x: i / 10 * w, y: 0 });
    nodes.push({ x: i / 10 * w, y: h });
  }
  for (let i = 1; i <= 6; i++) {
    nodes.push({ x: 0, y: i / 7 * h });
    nodes.push({ x: w, y: i / 7 * h });
  }
  // Interior nodes for web density
  for (let i = 0; i < 18; i++) {
    nodes.push({
      x: 100 + Math.random() * (w - 200),
      y: 80 + Math.random() * (h - 160)
    });
  }

  // Connect nearby nodes with subtle lines
  for (let i = 0; i < nodes.length; i++) {
    for (let j = i + 1; j < nodes.length; j++) {
      const dx = nodes[i].x - nodes[j].x;
      const dy = nodes[i].y - nodes[j].y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 350 && Math.random() > 0.55) {
        const opacity = (0.03 + Math.random() * 0.06).toFixed(3);
        const strokeW = (0.4 + Math.random() * 0.8).toFixed(1);
        const dash = Math.random() > 0.5
          ? `stroke-dasharray="${3 + Math.floor(Math.random() * 4)},${2 + Math.floor(Math.random() * 3)}"`
          : '';
        lines.push(
          `<line x1="${nodes[i].x.toFixed(0)}" y1="${nodes[i].y.toFixed(0)}" x2="${nodes[j].x.toFixed(0)}" y2="${nodes[j].y.toFixed(0)}" stroke="rgba(109,40,217,${opacity})" stroke-width="${strokeW}" ${dash} stroke-linecap="round"/>`
        );
      }
    }
  }

  // Small dots at some nodes
  const dots = nodes
    .filter(() => Math.random() > 0.7)
    .map(n => `<circle cx="${n.x.toFixed(0)}" cy="${n.y.toFixed(0)}" r="${(1 + Math.random() * 1.5).toFixed(1)}" fill="rgba(109,40,217,${(0.04 + Math.random() * 0.06).toFixed(2)})"/>`)
    .join('');

  return `<svg class="web-bg-svg" viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">${lines.join('')}${dots}</svg>`;
}

const webSvg = generateWebSvg();
