---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section id="blog" class="py-24 md:py-32 relative">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="text-violet-400 text-sm font-medium tracking-wider uppercase">Blog</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">
        Últimos
        <span class="text-violet-400">Insights</span>
      </h2>
      <p class="mt-4 text-neutral-400 max-w-2xl mx-auto text-lg">
        Análisis, guías prácticas y tendencias sobre IA aplicada al negocio.
      </p>
    </div>

    <!-- Blog grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {posts.map((post) => (
        <article class="group rounded-2xl border border-white/5 bg-white/[0.02] overflow-hidden hover:border-violet-500/20 transition-all duration-300">
          <!-- Image placeholder -->
          <div class="aspect-[16/9] bg-gradient-to-br from-violet-950/50 to-purple-950/50 flex items-center justify-center">
            <svg class="w-10 h-10 text-violet-500/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          </div>

          <div class="p-6">
            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.tags.slice(0, 2).map((tag: string) => (
                <span class="text-[11px] font-medium text-violet-300 bg-violet-500/10 px-2 py-0.5 rounded-full">{tag}</span>
              ))}
            </div>

            <h3 class="font-semibold text-lg mb-2 group-hover:text-violet-300 transition-colors leading-snug">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>

            <p class="text-sm text-neutral-400 mb-4 line-clamp-2">{post.data.description}</p>

            <div class="flex items-center justify-between text-xs text-neutral-500">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
              </time>
              <span>{post.data.readTime}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
