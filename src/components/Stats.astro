---
/**
 * Starburst visual built using Stripe DESIGN.md specs from VoltAgent:
 * - Gradient Accents: Ruby (#ea2261) → Magenta (#f96bee) for decorations
 * - Multi-layer depth philosophy: inner/mid/outer with different gradients
 * - Blue-tinted glow adapted as violet-tinted for TOF brand
 */

function makeSvgLines(count: number, gradId: string, minLen: number, maxLen: number, innerR: number): string {
  let out = '';
  const step = 360 / count;
  for (let i = 0; i < count; i++) {
    const deg = i * step + (Math.random() - 0.5) * step * 0.6;
    const a = deg * Math.PI / 180;
    const len = minLen + Math.random() * (maxLen - minLen);
    const x1 = (400 + Math.cos(a) * innerR).toFixed(1);
    const y1 = (400 + Math.sin(a) * innerR).toFixed(1);
    const x2 = (400 + Math.cos(a) * len).toFixed(1);
    const y2 = (400 + Math.sin(a) * len).toFixed(1);
    const op = (0.15 + Math.random() * 0.45).toFixed(2);
    const sw = (0.3 + Math.random() * 0.7).toFixed(2);
    out += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="url(#${gradId})" stroke-width="${sw}" opacity="${op}" stroke-linecap="round"/>`;
  }
  return out;
}

function makeSparkSvg(count: number): string {
  let out = '';
  for (let i = 0; i < count; i++) {
    const a = Math.random() * Math.PI * 2;
    const d = 120 + Math.random() * 250;
    const cx = (400 + Math.cos(a) * d).toFixed(1);
    const cy = (400 + Math.sin(a) * d).toFixed(1);
    const r = (0.8 + Math.random() * 1.5).toFixed(1);
    const dur = (2 + Math.random() * 4).toFixed(1);
    const delay = (Math.random() * 3).toFixed(1);
    out += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="#f0abfc" opacity="0"><animate attributeName="opacity" values="0;0.5;0" dur="${dur}s" begin="${delay}s" repeatCount="indefinite"/></circle>`;
  }
  return out;
}

// Generate all SVG content at build time
const layer1 = makeSvgLines(200, 'sg1', 60, 180, 8);
const layer2 = makeSvgLines(140, 'sg2', 120, 280, 12);
const layer3 = makeSvgLines(80, 'sg3', 200, 380, 6);
const sparkles = makeSparkSvg(30);

const fullSvg = `<svg class="starburst-svg" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
<defs>
  <radialGradient id="sg1" cx="50%" cy="50%" r="50%">
    <stop offset="0%" stop-color="#6d28d9" stop-opacity="1"/>
    <stop offset="60%" stop-color="#a78bfa" stop-opacity="0.6"/>
    <stop offset="100%" stop-color="#c084fc" stop-opacity="0.2"/>
  </radialGradient>
  <radialGradient id="sg2" cx="50%" cy="50%" r="50%">
    <stop offset="0%" stop-color="#7c3aed" stop-opacity="0.9"/>
    <stop offset="40%" stop-color="#c084fc" stop-opacity="0.5"/>
    <stop offset="70%" stop-color="#ea2261" stop-opacity="0.35"/>
    <stop offset="100%" stop-color="#f96bee" stop-opacity="0.1"/>
  </radialGradient>
  <radialGradient id="sg3" cx="50%" cy="50%" r="50%">
    <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.7"/>
    <stop offset="30%" stop-color="#ea2261" stop-opacity="0.4"/>
    <stop offset="60%" stop-color="#f96bee" stop-opacity="0.25"/>
    <stop offset="100%" stop-color="#fbbf24" stop-opacity="0.05"/>
  </radialGradient>
  <filter id="sbg"><feGaussianBlur stdDeviation="1.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
  <radialGradient id="cg" cx="50%" cy="50%" r="50%">
    <stop offset="0%" stop-color="#a78bfa" stop-opacity="0.3"/>
    <stop offset="50%" stop-color="#7c3aed" stop-opacity="0.1"/>
    <stop offset="100%" stop-color="#ea2261" stop-opacity="0"/>
  </radialGradient>
</defs>
<circle cx="400" cy="400" r="200" fill="url(#cg)"><animate attributeName="r" values="180;220;180" dur="8s" repeatCount="indefinite"/></circle>
<circle cx="400" cy="400" r="6" fill="#a78bfa" opacity="0.8"><animate attributeName="r" values="4;8;4" dur="3s" repeatCount="indefinite"/></circle>
<g class="sb-layer sb-l1" filter="url(#sbg)">${layer1}</g>
<g class="sb-layer sb-l2">${layer2}</g>
<g class="sb-layer sb-l3">${layer3}</g>
<g class="sb-sparkles">${sparkles}</g>
</svg>`;
---

<section class="stats-bar">
  <div class="starburst-wrap" aria-hidden="true">
    <svg class="starburst-svg spider-mother" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="wmg" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.15"/>
          <stop offset="50%" stop-color="#8b5cf6" stop-opacity="0.06"/>
          <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <!-- Central glow -->
      <circle cx="400" cy="400" r="200" fill="url(#wmg)"/>
      <circle cx="400" cy="400" r="4" fill="#a78bfa" opacity="0.6"/>
      <!-- Concentric web rings -->
      <circle cx="400" cy="400" r="40" fill="none" stroke="#8b5cf6" stroke-width="0.4" opacity="0.15"/>
      <circle cx="400" cy="400" r="90" fill="none" stroke="#8b5cf6" stroke-width="0.4" opacity="0.12"/>
      <circle cx="400" cy="400" r="150" fill="none" stroke="#8b5cf6" stroke-width="0.3" opacity="0.10"/>
      <circle cx="400" cy="400" r="220" fill="none" stroke="#8b5cf6" stroke-width="0.3" opacity="0.08"/>
      <circle cx="400" cy="400" r="300" fill="none" stroke="#8b5cf6" stroke-width="0.3" opacity="0.06"/>
      <circle cx="400" cy="400" r="380" fill="none" stroke="#8b5cf6" stroke-width="0.2" opacity="0.04"/>
      <!-- Radial spokes — 24 lines from center to edges -->
      <g stroke="#8b5cf6" stroke-linecap="round">
        <line x1="400" y1="400" x2="400" y2="10" stroke-width="0.5" opacity="0.12"/>
        <line x1="400" y1="400" x2="400" y2="790" stroke-width="0.5" opacity="0.12"/>
        <line x1="400" y1="400" x2="10" y2="400" stroke-width="0.5" opacity="0.12"/>
        <line x1="400" y1="400" x2="790" y2="400" stroke-width="0.5" opacity="0.12"/>
        <line x1="400" y1="400" x2="120" y2="120" stroke-width="0.4" opacity="0.10"/>
        <line x1="400" y1="400" x2="680" y2="120" stroke-width="0.4" opacity="0.10"/>
        <line x1="400" y1="400" x2="120" y2="680" stroke-width="0.4" opacity="0.10"/>
        <line x1="400" y1="400" x2="680" y2="680" stroke-width="0.4" opacity="0.10"/>
        <line x1="400" y1="400" x2="200" y2="50" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="600" y2="50" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="200" y2="750" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="600" y2="750" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="50" y2="200" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="750" y2="200" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="50" y2="600" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="750" y2="600" stroke-width="0.3" opacity="0.08"/>
        <line x1="400" y1="400" x2="30" y2="300" stroke-width="0.3" opacity="0.06"/>
        <line x1="400" y1="400" x2="770" y2="300" stroke-width="0.3" opacity="0.06"/>
        <line x1="400" y1="400" x2="30" y2="500" stroke-width="0.3" opacity="0.06"/>
        <line x1="400" y1="400" x2="770" y2="500" stroke-width="0.3" opacity="0.06"/>
        <line x1="400" y1="400" x2="300" y2="20" stroke-width="0.3" opacity="0.06"/>
        <line x1="400" y1="400" x2="500" y2="20" stroke-width="0.3" opacity="0.06"/>
        <line x1="400" y1="400" x2="300" y2="780" stroke-width="0.3" opacity="0.06"/>
        <line x1="400" y1="400" x2="500" y2="780" stroke-width="0.3" opacity="0.06"/>
      </g>
      <!-- Decorative web intersections -->
      <g fill="#a78bfa">
        <circle cx="400" cy="310" r="1.5" opacity="0.2"/>
        <circle cx="400" cy="490" r="1.5" opacity="0.2"/>
        <circle cx="310" cy="400" r="1.5" opacity="0.2"/>
        <circle cx="490" cy="400" r="1.5" opacity="0.2"/>
        <circle cx="340" cy="340" r="1.2" opacity="0.15"/>
        <circle cx="460" cy="340" r="1.2" opacity="0.15"/>
        <circle cx="340" cy="460" r="1.2" opacity="0.15"/>
        <circle cx="460" cy="460" r="1.2" opacity="0.15"/>
      </g>
    </svg>
  </div>

  <div class="container">
    <div class="stats-grid">
      <div class="reveal stat-item st1">
        <h3 class="slot-counter" data-prefix="+" data-target="500">+0</h3>
        <p>Reuniones agendadas</p>
      </div>
      <div class="reveal stat-item st2">
        <h3 class="slot-counter" data-prefix="+" data-target="30">+0</h3>
        <p>Empresas confían en nosotros</p>
      </div>
      <div class="reveal stat-item st3">
        <h3 class="slot-counter" data-prefix="x" data-target="10">x0</h3>
        <p>Leads calificados</p>
      </div>
      <div class="reveal stat-item st4">
        <h3 class="slot-counter" data-prefix="+" data-target="8">+0</h3>
        <p>Mercados alcanzados</p>
      </div>
    </div>
  </div>
</section>
