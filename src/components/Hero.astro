---
---

    <section class="hero">
      <div class="glow g1"></div>
      <div class="glow g2"></div>
      <div class="float-el fl1"></div>
      <div class="float-el fl2"></div>
      <div class="float-el fl3"></div>

      <!-- PREMIUM HERO ANIMATION: THE PIPELINE -->
      <div class="pipe-wrap" aria-hidden="true">
        <!-- Living gradient blobs -->
        <div class="pipe-blob pipe-blob-1"></div>
        <div class="pipe-blob pipe-blob-2"></div>
        <div class="pipe-blob pipe-blob-3"></div>

        <!-- Connecting pulse lines -->
        <div class="pipe-line pipe-line-1"></div>
        <div class="pipe-line pipe-line-2"></div>
        <div class="pipe-line pipe-line-3"></div>
      </div>
      <!-- END PREMIUM HERO ANIMATION -->

      <!-- Floating notification cards (same system as Stats/Services) -->
      <div class="web-card wc-hero-1 reveal-scale">
        <div class="pc-icon pc-green"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
        <div class="pc-body"><div class="pc-title">Reuni&oacute;n confirmada</div><div class="pc-sub">Mi&eacute;rcoles 10:00 AM</div></div>
      </div>
      <div class="web-card wc-hero-2 reveal-scale">
        <div class="pc-icon pc-blue"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.064 2.064 0 110-4.128 2.064 2.064 0 010 4.128zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg></div>
        <div class="pc-body"><div class="pc-title">Nuevo lead calificado</div><div class="pc-sub">VP Comercial &bull; SaaS B2B</div></div>
      </div>
      <div class="web-card wc-hero-3 reveal-scale">
        <div class="pc-icon pc-violet"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
        <div class="pc-body"><div class="pc-title">Propuesta aprobada</div><div class="pc-sub">Presupuesto firmado &check;</div></div>
      </div>
      <div class="web-card wc-hero-4 reveal-scale">
        <div class="pc-icon pc-amber"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
        <div class="pc-body"><div class="pc-title">10 reuniones este mes</div><div class="pc-sub">+80% vs mes anterior</div></div>
      </div>
      <div class="web-card wc-hero-5 reveal-scale">
        <div class="pc-icon pc-green"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
        <div class="pc-body"><div class="pc-title">Demo agendada</div><div class="pc-sub">Jueves 15:00 &bull; CTO</div></div>
      </div>
      <div class="web-card wc-hero-6 reveal-scale">
        <div class="pc-icon pc-blue"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg></div>
        <div class="pc-body"><div class="pc-title">Pipeline creciendo</div><div class="pc-sub">4 deals en negociaci&oacute;n</div></div>
      </div>

      <div class="container">
        <div class="hero-content">
          <div class="hero-badge">Prospección B2B que genera resultados</div>
          <h1>
            Llenamos tu agenda de citas con <em>clientes de alto valor.</em>
          </h1>
          <p>
            Deja de depender de referidos inconstantes o campañas que no
            convierten. Implementamos un sistema de prospección predecible que
            pone a tu cliente ideal frente a ti cada semana.
          </p>
          <div class="hero-actions">
            <a
              href="https://calendar.app.google/Jxg7er6LkiL6tGEw6"
              onclick="
                gtag('event', 'agendar_reunion', {
                  event_category: 'conversion',
                  event_label: 'click_boton_agendar',
                })
              "
              class="btn btn-primary magnetic-btn"
              rel="noopener"
              target="_blank"
              >Agendar reunión
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                height="18"
                width="18"
              >
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" /></svg></a
            ><a href="#proceso" class="btn btn-ghost">Ver cómo funciona</a>
          </div>
        </div>
      </div>
    </section>
