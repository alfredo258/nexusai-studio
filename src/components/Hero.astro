---

---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-violet-950/40 via-neutral-950 to-purple-950/30 animate-gradient" aria-hidden="true"></div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);" aria-hidden="true"></div>

  <!-- Glow orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-violet-600/20 rounded-full blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-600/15 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="animate-fade-up inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-violet-500/30 bg-violet-500/10 text-violet-300 text-sm mb-8">
      <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse-dot"></span>
      Agencia AI-Native &middot; Resultados Reales
    </div>

    <!-- Heading -->
    <h1 class="animate-fade-up delay-100 text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6">
      Construimos el
      <span class="bg-gradient-to-r from-violet-400 via-purple-400 to-violet-500 bg-clip-text text-transparent">
        Futuro de tu Negocio
      </span>
      con IA
    </h1>

    <!-- Subtitle -->
    <p class="animate-fade-up delay-200 text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Automatizamos procesos, creamos agentes inteligentes y desarrollamos soluciones de IA a medida que multiplican tus resultados. Sin hype, solo impacto medible.
    </p>

    <!-- CTAs -->
    <div class="animate-fade-up delay-300 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#contacto" class="w-full sm:w-auto px-8 py-3.5 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-violet-500/25 text-center">
        Agenda una Consulta Gratis
      </a>
      <a href="#servicios" class="w-full sm:w-auto px-8 py-3.5 border border-white/10 hover:border-white/25 text-neutral-300 hover:text-white font-medium rounded-xl transition-all duration-200 text-center">
        Ver Servicios
      </a>
    </div>

    <!-- Social proof -->
    <div class="animate-fade-up delay-400 mt-16 flex flex-col sm:flex-row items-center justify-center gap-8 text-sm text-neutral-500">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-violet-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <span>+50 proyectos de IA entregados</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        <span>ROI promedio 340%</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>Entrega en 2-4 semanas</span>
      </div>
    </div>
  </div>
</section>
