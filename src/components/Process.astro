---
const steps = [
  {
    number: '01',
    title: 'Diagnóstico',
    description: 'Analizamos tu operación, identificamos oportunidades de IA y definimos objetivos claros con métricas de éxito.',
  },
  {
    number: '02',
    title: 'Diseño & Prototipo',
    description: 'Creamos la arquitectura de la solución y un prototipo funcional en 5 días para validar el enfoque.',
  },
  {
    number: '03',
    title: 'Desarrollo',
    description: 'Implementamos la solución con sprints semanales, demos en vivo y feedback continuo de tu equipo.',
  },
  {
    number: '04',
    title: 'Lanzamiento & Soporte',
    description: 'Desplegamos en producción, capacitamos a tu equipo y monitorizamos el rendimiento para optimizar resultados.',
  },
];
---

<section id="proceso" class="py-24 md:py-32 relative">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="text-violet-400 text-sm font-medium tracking-wider uppercase">Proceso</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">
        De la Idea al
        <span class="text-violet-400">Impacto Real</span>
      </h2>
      <p class="mt-4 text-neutral-400 max-w-2xl mx-auto text-lg">
        Un proceso probado que minimiza riesgo y maximiza velocidad. Resultados tangibles desde la primera semana.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class="relative">
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-full w-full h-px bg-gradient-to-r from-violet-500/30 to-transparent" aria-hidden="true"></div>
          )}
          <div class="text-5xl font-black text-violet-500/10 mb-2">{step.number}</div>
          <h3 class="text-lg font-semibold mb-2">{step.title}</h3>
          <p class="text-sm text-neutral-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
