---
import JsonLd from './JsonLd.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many emails do you send per day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We send 130+ personalized emails per day per mailbox, with AI-crafted messaging, smart sequences, and deliverability optimization to maximize open and reply rates."
      }
    },
    {
      "@type": "Question",
      "name": "How quickly can I see results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most clients start seeing replies within the first week of campaign launch. Qualified meetings typically start booking within 2-3 weeks as sequences warm up."
      }
    },
    {
      "@type": "Question",
      "name": "Do you work with my industry?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We work with B2B companies across SaaS, agencies, consulting, and professional services. If you sell to other businesses, we can build your pipeline."
      }
    },
    {
      "@type": "Question",
      "name": "What makes you different from other outbound agencies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We combine AI-powered personalization with proven outbound frameworks. Every email feels like it was written by a human who did their research — because our AI actually did."
      }
    }
  ]
};

const questions = [
  { value: 'pricing', label: 'What does it cost?' },
  { value: 'timeline', label: 'How fast can we start?' },
  { value: 'results', label: 'What results can I expect?' },
  { value: 'call', label: 'I want a free strategy call' },
];
---

<section id="faq" class="py-24 md:py-32 relative">
  <JsonLd data={faqSchema} />

  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: FAQ Content -->
      <div>
        <span class="text-violet-400 text-sm font-medium tracking-wider uppercase">FAQ</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight mb-6">
          Got Questions?
          <span class="text-violet-400">We've Got Answers</span>
        </h2>
        <p class="text-neutral-400 text-lg mb-8">
          Everything you need to know about how The Outbound Force fills your pipeline with qualified meetings.
        </p>

        <!-- FAQ Accordion (CSS-only with details/summary) -->
        <div class="space-y-3">
          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              How many emails do you send per day?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">We send 130+ personalized emails per day per mailbox, with AI-crafted messaging, smart sequences, and deliverability optimization to maximize open and reply rates.</p>
          </details>

          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              How quickly can I see results?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">Most clients start seeing replies within the first week. Qualified meetings typically start booking within 2-3 weeks as sequences warm up.</p>
          </details>

          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              Do you work with my industry?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">We work with B2B companies across SaaS, agencies, consulting, and professional services. If you sell to other businesses, we can build your pipeline.</p>
          </details>

          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              What makes you different from other outbound agencies?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">We combine AI-powered personalization with proven outbound frameworks. Every email feels like it was written by a human who did their research — because our AI actually did.</p>
          </details>
        </div>
      </div>

      <!-- Right: Chat Simulator -->
      <div class="relative">
        <div class="bg-neutral-900/80 border border-white/10 rounded-2xl overflow-hidden shadow-2xl shadow-violet-500/5">
          <!-- Chat header -->
          <div class="flex items-center gap-3 p-4 border-b border-white/5">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-xs font-bold">T</div>
            <div>
              <p class="text-sm font-medium">TOF Assistant</p>
              <p class="text-xs text-green-400 flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse-dot"></span>
                Online
              </p>
            </div>
          </div>

          <!-- Chat messages -->
          <div class="p-4 space-y-4 min-h-[320px]">
            <!-- Bot message -->
            <div class="flex gap-3">
              <div class="w-6 h-6 rounded-full bg-violet-500/20 flex-shrink-0 flex items-center justify-center text-[10px] text-violet-400 mt-1">T</div>
              <div class="bg-white/5 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[80%]">
                <p class="text-sm text-neutral-300">Hey! I'm the TOF assistant. I can help you understand how we fill your pipeline with qualified meetings using AI-powered outbound.</p>
              </div>
            </div>

            <!-- Bot message 2 -->
            <div class="flex gap-3">
              <div class="w-6 h-6 rounded-full bg-violet-500/20 flex-shrink-0 flex items-center justify-center text-[10px] text-violet-400 mt-1">T</div>
              <div class="bg-white/5 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[80%]">
                <p class="text-sm text-neutral-300">What would you like to know?</p>
              </div>
            </div>

            <!-- Quick reply buttons -->
            <div class="flex flex-wrap gap-2 pl-9">
              {questions.map((q) => (
                <a href="#contact" class="inline-block px-3 py-1.5 text-xs font-medium text-violet-300 border border-violet-500/30 rounded-full hover:bg-violet-500/10 transition-colors">
                  {q.label}
                </a>
              ))}
            </div>
          </div>

          <!-- Chat input -->
          <div class="p-4 border-t border-white/5">
            <form action="#contact" class="flex gap-2">
              <input
                type="text"
                placeholder="Ask me anything..."
                class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-sm placeholder-neutral-500 focus:outline-none focus:border-violet-500/50 transition-colors"
                aria-label="Type your question"
              />
              <button type="submit" class="px-4 py-2.5 bg-violet-600 hover:bg-violet-500 rounded-xl transition-colors" aria-label="Send message">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
