---
import JsonLd from './JsonLd.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué tipo de proyectos de IA realizan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Desarrollamos agentes IA autónomos, chatbots inteligentes, automatización de procesos, sistemas RAG y webs con IA integrada. Cada solución se diseña a medida para resolver problemas específicos de negocio."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo tarda un proyecto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La mayoría de proyectos se entregan en 2-4 semanas. MVPs funcionales en 1 semana. Proyectos enterprise complejos en 6-8 semanas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué ROI puedo esperar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nuestros clientes reportan un ROI promedio del 340% en el primer año. La automatización típica reduce costos operativos entre 40-70%."
      }
    },
    {
      "@type": "Question",
      "name": "¿Trabajan con empresas pequeñas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, trabajamos con startups, PYMEs y enterprises. Tenemos paquetes adaptados a cada tamaño de empresa, desde consultoría puntual hasta implementaciones completas."
      }
    }
  ]
};

const questions = [
  { value: 'servicios', label: '¿Qué servicios ofrecen?' },
  { value: 'precios', label: '¿Cuánto cuesta un proyecto?' },
  { value: 'tiempo', label: '¿Cuánto tardan en entregar?' },
  { value: 'consulta', label: 'Quiero una consulta gratuita' },
];
---

<section id="chatbot" class="py-24 md:py-32 relative">
  <JsonLd data={faqSchema} />

  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: FAQ Content -->
      <div>
        <span class="text-violet-400 text-sm font-medium tracking-wider uppercase">AI Assistant</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight mb-6">
          Tu Asistente de IA
          <span class="text-violet-400">Disponible 24/7</span>
        </h2>
        <p class="text-neutral-400 text-lg mb-8">
          Nuestro chatbot inteligente puede responder tus preguntas, calificar tu proyecto y conectarte con el especialista adecuado. Sin esperas, sin formularios eternos.
        </p>

        <!-- FAQ Accordion (CSS-only with details/summary) -->
        <div class="space-y-3">
          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              ¿Qué tipo de proyectos de IA realizan?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">Desarrollamos agentes IA autónomos, chatbots inteligentes, automatización de procesos, sistemas RAG y webs con IA integrada. Cada solución se diseña a medida para resolver problemas específicos de negocio.</p>
          </details>

          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              ¿Cuánto tiempo tarda un proyecto?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">La mayoría se entregan en 2-4 semanas. MVPs funcionales en 1 semana. Proyectos enterprise complejos en 6-8 semanas.</p>
          </details>

          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              ¿Qué ROI puedo esperar?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">Nuestros clientes reportan un ROI promedio del 340% en el primer año. La automatización típica reduce costos operativos entre 40-70%.</p>
          </details>

          <details class="group border border-white/5 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-sm font-medium hover:bg-white/[0.02] transition-colors">
              ¿Trabajan con empresas pequeñas?
              <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="px-4 pb-4 text-sm text-neutral-400">Sí, trabajamos con startups, PYMEs y enterprises. Tenemos paquetes adaptados a cada tamaño de empresa.</p>
          </details>
        </div>
      </div>

      <!-- Right: Chatbot Simulator -->
      <div class="relative">
        <div class="bg-neutral-900/80 border border-white/10 rounded-2xl overflow-hidden shadow-2xl shadow-violet-500/5">
          <!-- Chat header -->
          <div class="flex items-center gap-3 p-4 border-b border-white/5">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-xs font-bold">AI</div>
            <div>
              <p class="text-sm font-medium">NexusAI Assistant</p>
              <p class="text-xs text-green-400 flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse-dot"></span>
                Online
              </p>
            </div>
          </div>

          <!-- Chat messages -->
          <div class="p-4 space-y-4 min-h-[320px]">
            <!-- Bot message -->
            <div class="flex gap-3">
              <div class="w-6 h-6 rounded-full bg-violet-500/20 flex-shrink-0 flex items-center justify-center text-[10px] text-violet-400 mt-1">AI</div>
              <div class="bg-white/5 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[80%]">
                <p class="text-sm text-neutral-300">Hola, soy el asistente de NexusAI. Puedo ayudarte a entender nuestros servicios y evaluar si somos el partner ideal para tu proyecto.</p>
              </div>
            </div>

            <!-- Bot message 2 -->
            <div class="flex gap-3">
              <div class="w-6 h-6 rounded-full bg-violet-500/20 flex-shrink-0 flex items-center justify-center text-[10px] text-violet-400 mt-1">AI</div>
              <div class="bg-white/5 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[80%]">
                <p class="text-sm text-neutral-300">¿Sobre qué te gustaría saber más?</p>
              </div>
            </div>

            <!-- Quick reply buttons -->
            <div class="flex flex-wrap gap-2 pl-9">
              {questions.map((q) => (
                <a href="#contacto" class="inline-block px-3 py-1.5 text-xs font-medium text-violet-300 border border-violet-500/30 rounded-full hover:bg-violet-500/10 transition-colors">
                  {q.label}
                </a>
              ))}
            </div>
          </div>

          <!-- Chat input -->
          <div class="p-4 border-t border-white/5">
            <form action="#contacto" class="flex gap-2">
              <input
                type="text"
                placeholder="Escribe tu pregunta..."
                class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-sm placeholder-neutral-500 focus:outline-none focus:border-violet-500/50 transition-colors"
                aria-label="Escribe tu pregunta al asistente"
              />
              <button type="submit" class="px-4 py-2.5 bg-violet-600 hover:bg-violet-500 rounded-xl transition-colors" aria-label="Enviar mensaje">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
