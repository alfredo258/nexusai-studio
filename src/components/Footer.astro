---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-sm font-bold">N</div>
          <span class="font-semibold text-lg tracking-tight">NexusAI</span>
        </a>
        <p class="text-sm text-neutral-400 leading-relaxed">
          Agencia AI-Native. Construimos soluciones de IA que generan impacto real en tu negocio.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold mb-4">Servicios</h3>
        <ul class="space-y-2 text-sm text-neutral-400">
          <li><a href="#servicios" class="hover:text-white transition-colors">Agentes IA</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Webs Inteligentes</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Automatización</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Consultoría IA</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold mb-4">Empresa</h3>
        <ul class="space-y-2 text-sm text-neutral-400">
          <li><a href="#" class="hover:text-white transition-colors">Sobre Nosotros</a></li>
          <li><a href="#blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="#contacto" class="hover:text-white transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold mb-4">Contacto</h3>
        <ul class="space-y-2 text-sm text-neutral-400">
          <li>hola@nexusai.studio</li>
          <li>Madrid, España</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-neutral-500">
      <p>&copy; {year} NexusAI Studio. Todos los derechos reservados.</p>
      <div class="flex items-center gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
