      border: 1px solid var(--border);
      z-index: 100;
      letter-spacing: 0.03em;
      white-space: nowrap;
    }
  </style>

<script is:inline>
    function initShowcase() {
      const track = document.querySelector('[data-showcase-track]');
      const texts = document.querySelectorAll('[data-showcase-text]');
      const devices = document.querySelectorAll('[data-showcase-device]');
      const titles = document.querySelectorAll('[data-showcase-title]');
      const dots = document.querySelectorAll('[data-dot]');

      if (!track || !texts.length || !devices.length) return;

      const totalSlides = 5;
      let currentSlide = -1;
      let ticking = false;

      function onScroll() {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => {
            ticking = false;
            update();
          });
        }
      }

      function update() {
        const rect = track.getBoundingClientRect();
        const viewH = window.innerHeight;
        const offset = viewH * 0.1;
        const scrolled = -(rect.top - offset);
        const totalH = rect.height - viewH + offset;
        const progress = Math.max(0, Math.min(1, scrolled / totalH));

        // Which slide are we on?
        const slideProgress = progress * totalSlides;
        const slide = Math.min(Math.floor(slideProgress), totalSlides - 1);
        const fillWithinSlide = slideProgress - slide;

        // Update fill on titles
        titles.forEach((t, i) => {
          t.style.setProperty('--fill', i === slide ? String(Math.min(fillWithinSlide, 1)) : '0');
        });
        texts.forEach((t, i) => {
          t.style.setProperty('--fill', i === slide ? String(Math.min(fillWithinSlide, 1)) : '0');
        });

        // Switch active slide
        if (slide !== currentSlide) {
          currentSlide = slide;
          texts.forEach((t, i) => t.classList.toggle('active', i === slide));
          devices.forEach((d, i) => d.classList.toggle('active', i === slide));
          dots.forEach((d, i) => d.classList.toggle('active', i === slide));
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(update, 150);
      });

      // Initial state
      currentSlide = 0;
      update();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initShowcase);
    } else {
      initShowcase();
    }
</script>
