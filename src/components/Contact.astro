---

---

<section id="contacto" class="py-24 md:py-32 relative">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-12">
        <span class="text-violet-400 text-sm font-medium tracking-wider uppercase">Contacto</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight">
          ¿Listo para
          <span class="text-violet-400">Transformar tu Negocio</span>?
        </h2>
        <p class="mt-4 text-neutral-400 text-lg">
          Cuéntanos tu reto y te proponemos una solución en menos de 48h. Sin compromiso.
        </p>
      </div>

      <!-- Contact form -->
      <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-5">
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-neutral-300 mb-2">Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-neutral-500 focus:outline-none focus:border-violet-500/50 transition-colors"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-neutral-300 mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-neutral-500 focus:outline-none focus:border-violet-500/50 transition-colors"
              placeholder="tu@empresa.com"
            />
          </div>
        </div>

        <div>
          <label for="company" class="block text-sm font-medium text-neutral-300 mb-2">Empresa</label>
          <input
            type="text"
            id="company"
            name="company"
            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-neutral-500 focus:outline-none focus:border-violet-500/50 transition-colors"
            placeholder="Nombre de tu empresa"
          />
        </div>

        <div>
          <label for="service" class="block text-sm font-medium text-neutral-300 mb-2">¿Qué servicio te interesa?</label>
          <select
            id="service"
            name="service"
            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-neutral-400 focus:outline-none focus:border-violet-500/50 transition-colors"
          >
            <option value="">Selecciona un servicio</option>
            <option value="agentes">Agentes IA Autónomos</option>
            <option value="webs">Webs Inteligentes</option>
            <option value="automatizacion">Automatización de Procesos</option>
            <option value="consultoria">Consultoría Estratégica IA</option>
            <option value="chatbots">Chatbots & Asistentes</option>
            <option value="rag">RAG & Knowledge Bases</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-neutral-300 mb-2">Cuéntanos tu reto</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-neutral-500 focus:outline-none focus:border-violet-500/50 transition-colors resize-none"
            placeholder="Describe brevemente qué problema quieres resolver con IA..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-8 py-3.5 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-violet-500/25"
        >
          Solicitar Consulta Gratuita
        </button>

        <p class="text-xs text-neutral-500 text-center">
          Respondemos en menos de 48 horas. Sin spam, sin compromisos.
        </p>
      </form>
    </div>
  </div>
</section>
