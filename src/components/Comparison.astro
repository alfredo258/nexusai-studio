---
---

<section class="cmp-section" id="comparacion">
  <div class="container">
    <div class="reveal cmp-header">
      <div class="section-label">Por qué TOF</div>
      <h2 class="section-title">Mejor que armar un equipo<br/>o contratar una agencia tradicional.</h2>
      <p class="section-desc">Resultados en 14 días, no en 6 meses. Fee fijo, no comisiones. Sin contratar SDR ni esperar que aprenda tu producto.</p>
    </div>

    <div class="cmp-grid reveal">
      <!-- Column headers -->
      <div class="cmp-feature-col">
        <div class="cmp-head cmp-head-feature"></div>
        <ul class="cmp-features">
          <li>Tiempo hasta primeras reuniones</li>
          <li>Inversión mensual</li>
          <li>Riesgo de contratación</li>
          <li>Experiencia multicanal</li>
          <li>Personalización con IA</li>
          <li>Reportes y optimización</li>
          <li>Escalabilidad</li>
        </ul>
      </div>

      <!-- TOF col (highlighted) -->
      <div class="cmp-col cmp-col-us">
        <div class="cmp-head">
          <div class="cmp-logo">The Outbound<em>Force</em></div>
          <span class="cmp-badge">Recomendado</span>
        </div>
        <ul class="cmp-values">
          <li><span class="cmp-val-label">Tiempo hasta primeras reuniones</span><span class="cmp-val cmp-good">7-14 días</span></li>
          <li><span class="cmp-val-label">Inversión mensual</span><span class="cmp-val cmp-good">Desde USD 1.500 fijo · sin % revenue</span></li>
          <li><span class="cmp-val-label">Riesgo de contratación</span><span class="cmp-val cmp-good">Cero · si en 30 días no hay reuniones, reajustamos sin costo</span></li>
          <li><span class="cmp-val-label">Experiencia multicanal</span><span class="cmp-val cmp-good">LinkedIn + Email + Meta + Google</span></li>
          <li><span class="cmp-val-label">Personalización con IA</span><span class="cmp-val cmp-good">Incluida en cada mensaje</span></li>
          <li><span class="cmp-val-label">Reportes y optimización</span><span class="cmp-val cmp-good">Semanales + ajustes continuos</span></li>
          <li><span class="cmp-val-label">Escalabilidad</span><span class="cmp-val cmp-good">Subís volumen sin sumar staff</span></li>
        </ul>
      </div>

      <!-- Agencia tradicional -->
      <div class="cmp-col">
        <div class="cmp-head">
          <div class="cmp-logo cmp-logo-plain">Agencia tradicional</div>
        </div>
        <ul class="cmp-values">
          <li><span class="cmp-val-label">Tiempo hasta primeras reuniones</span><span class="cmp-val cmp-mid">1-3 meses</span></li>
          <li><span class="cmp-val-label">Inversión mensual</span><span class="cmp-val cmp-mid">Alta + fees ocultos</span></li>
          <li><span class="cmp-val-label">Riesgo de contratación</span><span class="cmp-val cmp-mid">Contratos largos</span></li>
          <li><span class="cmp-val-label">Experiencia multicanal</span><span class="cmp-val cmp-mid">Suele ser solo un canal</span></li>
          <li><span class="cmp-val-label">Personalización con IA</span><span class="cmp-val cmp-bad">Casi nunca</span></li>
          <li><span class="cmp-val-label">Reportes y optimización</span><span class="cmp-val cmp-mid">Mensuales, poco accionables</span></li>
          <li><span class="cmp-val-label">Escalabilidad</span><span class="cmp-val cmp-mid">Depende del equipo asignado</span></li>
        </ul>
      </div>

      <!-- Equipo in-house -->
      <div class="cmp-col">
        <div class="cmp-head">
          <div class="cmp-logo cmp-logo-plain">Equipo in-house</div>
        </div>
        <ul class="cmp-values">
          <li><span class="cmp-val-label">Tiempo hasta primeras reuniones</span><span class="cmp-val cmp-bad">3-6 meses</span></li>
          <li><span class="cmp-val-label">Inversión mensual</span><span class="cmp-val cmp-bad">Sueldos + tools + training</span></li>
          <li><span class="cmp-val-label">Riesgo de contratación</span><span class="cmp-val cmp-bad">Alto — indemnizaciones, rotación</span></li>
          <li><span class="cmp-val-label">Experiencia multicanal</span><span class="cmp-val cmp-bad">Limitada al perfil contratado</span></li>
          <li><span class="cmp-val-label">Personalización con IA</span><span class="cmp-val cmp-mid">Requiere consultor externo</span></li>
          <li><span class="cmp-val-label">Reportes y optimización</span><span class="cmp-val cmp-mid">Según skill del equipo</span></li>
          <li><span class="cmp-val-label">Escalabilidad</span><span class="cmp-val cmp-bad">Contratar más gente</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .cmp-section { padding: 6rem 0 5rem; position: relative; }
  .cmp-header { text-align: center; max-width: 680px; margin: 0 auto 3.5rem; }

  .cmp-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1fr 1fr;
    gap: 0;
    background: rgba(109,40,217,0.03);
    border: 1px solid rgba(109,40,217,0.14);
    border-radius: 20px;
    position: relative;
    margin-top: 16px;
  }

  .cmp-feature-col,
  .cmp-col {
    padding: 1.5rem 1.25rem 1.75rem;
    border-right: 1px solid rgba(109,40,217,0.08);
  }
  .cmp-col:last-child { border-right: none; }

  .cmp-feature-col {
    background: rgba(0,0,0,0.02);
  }

  .cmp-head {
    height: 70px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(109,40,217,0.1);
  }
  .cmp-head-feature { border-bottom-color: transparent; }

  .cmp-logo {
    font-family: var(--font-display, 'DM Sans', sans-serif);
    font-size: 0.95rem;
    font-weight: 800;
    color: #0a0a0a;
    letter-spacing: -0.3px;
  }
  .cmp-logo em { font-style: italic; color: #6d28d9; }
  .cmp-logo-plain { color: #555; font-weight: 600; letter-spacing: 0; }

  .cmp-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.35rem 0.85rem;
    background: #6d28d9;
    color: #fff;
    font-family: var(--font-mono, 'Space Mono', monospace);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: 0 4px 10px rgba(109,40,217,0.35), 0 0 0 3px #faf9f7;
  }

  .cmp-col-us {
    background: linear-gradient(180deg, rgba(109,40,217,0.1), rgba(109,40,217,0.03));
    position: relative;
    transform: translateY(-8px);
    padding-top: 2rem !important;
    padding-bottom: 2.25rem !important;
    border-radius: 14px;
    box-shadow: 0 12px 28px -10px rgba(109,40,217,0.25);
  }
  .cmp-col-us::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-left: 2px solid rgba(109,40,217,0.4);
    border-right: 2px solid rgba(109,40,217,0.4);
  }

  .cmp-features, .cmp-values {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .cmp-features li,
  .cmp-values li {
    padding: 0.9rem 0;
    font-size: 0.84rem;
    line-height: 1.4;
    border-bottom: 1px dashed rgba(109,40,217,0.08);
    min-height: 52px;
    display: flex;
    align-items: center;
  }
  .cmp-features li:last-child,
  .cmp-values li:last-child { border-bottom: none; }
  .cmp-features li {
    color: #333;
    font-weight: 600;
  }

  .cmp-val-label { display: none; }
  .cmp-val {
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.4;
  }
  .cmp-good { color: #059669; font-weight: 600; }
  .cmp-mid { color: #92400e; }
  .cmp-bad { color: #b91c1c; }
  .cmp-col:not(.cmp-col-us) .cmp-val { color: #666; }
  .cmp-col:not(.cmp-col-us) .cmp-good { color: #059669; }
  .cmp-col:not(.cmp-col-us) .cmp-mid { color: #b45309; }
  .cmp-col:not(.cmp-col-us) .cmp-bad { color: #dc2626; }

  @media (max-width: 900px) {
    .cmp-grid {
      grid-template-columns: 1fr;
      background: transparent;
      border: none;
    }
    .cmp-feature-col { display: none; }
    .cmp-col {
      margin-bottom: 1rem;
      border: 1px solid rgba(109,40,217,0.14);
      border-radius: 16px;
      background: rgba(109,40,217,0.02);
    }
    .cmp-col-us::before { border-radius: 16px; }
    .cmp-val-label {
      display: block;
      font-size: 0.72rem;
      color: #777;
      margin-right: auto;
      font-weight: 500;
    }
    .cmp-values li {
      justify-content: space-between;
      gap: 1rem;
    }
  }
</style>
