---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Testimonials from '../components/Testimonials.astro';
import Clients from '../components/Clients.astro';
import Calendar from '../components/Calendar.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "The Outbound Force",
  "description": "Implementamos un sistema de prospección B2B predecible para empresas. LinkedIn, Email Marketing, Meta Ads y Google Ads. +500 reuniones agendadas.",
  "url": "https://theoutboundforce.com",
  "areaServed": ["Argentina", "LATAM", "España", "USA"],
  "serviceType": ["Prospección B2B", "Generación de Leads", "Email Marketing", "LinkedIn Outreach", "Meta Ads", "Google Ads", "Landing Pages"],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "5"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Rosario",
    "addressRegion": "Santa Fe",
    "addressCountry": "Argentina"
  }
};
---

<Layout
  title="The Outbound Force — Prospección B2B que llena tu agenda de reuniones"
  description="Implementamos un sistema de prospección B2B predecible para empresas. LinkedIn, Email Marketing, Meta Ads y Google Ads. +500 reuniones agendadas. Agendá tu llamada gratis."
>
  <JsonLd data={serviceSchema} />
  <Header />
  <main>
    <Hero />
    <Stats />
    <div class="premium-divider" aria-hidden="true"><div class="premium-divider-line"><div class="premium-divider-accent"></div></div></div>
    <Services />
    <Process />
    <div class="premium-divider" aria-hidden="true"><div class="premium-divider-line"><div class="premium-divider-accent"></div></div></div>
    <Testimonials />
    <Clients />
    <Calendar />
  </main>
  <Footer />

  <!-- Scripts -->
  <script is:inline>
    // Scroll reveal observer
    const allR = document.querySelectorAll(".reveal,.reveal-left,.reveal-right,.reveal-scale");
    const rObs = new IntersectionObserver((e) => {
      e.forEach((e) => { e.isIntersecting && e.target.classList.add("active"); });
    }, { threshold: 0.08, rootMargin: "0px 0px -40px 0px" });
    allR.forEach((e) => rObs.observe(e));

    // Nav scroll effect
    window.addEventListener("scroll", () => {
      document.getElementById("navbar").classList.toggle("scrolled", window.scrollY > 50);
    });

    // Mobile menu
    document.getElementById("menuToggle").addEventListener("click", () => {
      document.getElementById("navLinks").classList.toggle("open");
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach((e) => {
      e.addEventListener("click", (t) => {
        t.preventDefault();
        const n = document.querySelector(e.getAttribute("href"));
        n && (n.scrollIntoView({ behavior: "smooth", block: "start" }),
          document.getElementById("navLinks").classList.remove("open"));
      });
    });

    // Slot counter animation
    const slotCounters = document.querySelectorAll(".slot-counter");
    const slotObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.dataset.target);
        const prefix = el.dataset.prefix || "";
        const fps = 1000 / 60;
        const totalFrames = Math.round(2000 / fps);
        let frame = 0;
        const timer = setInterval(() => {
          frame++;
          const progress = 1 - Math.pow(1 - frame / totalFrames, 4);
          el.textContent = prefix + Math.round(target * progress);
          if (frame === totalFrames) clearInterval(timer);
        }, fps);
        slotObs.unobserve(el);
      });
    }, { threshold: 0.5 });
    slotCounters.forEach((e) => slotObs.observe(e));

    // Active nav indicator on scroll
    const navSections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
    const navObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach(link => {
            link.classList.toggle('nav-active', link.getAttribute('href') === '#' + id);
          });
        }
      });
    }, { threshold: 0.3, rootMargin: '-80px 0px -50% 0px' });
    navSections.forEach(s => navObs.observe(s));

    // Parallax floating elements
    document.addEventListener("mousemove", (e) => {
      const els = document.querySelectorAll(".float-el");
      const mx = 20 * (e.clientX / window.innerWidth - 0.5);
      const my = 20 * (e.clientY / window.innerHeight - 0.5);
      els.forEach((el, i) => {
        const factor = 0.4 * (i + 1);
        el.style.transform = `translate(${mx * factor}px,${my * factor}px)`;
      });
    });

    // === MAGNETIC BUTTONS ===
    document.querySelectorAll('.magnetic-btn').forEach(btn => {
      const strength = 0.3;
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        btn.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = 'translate(0, 0)';
        btn.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
        setTimeout(() => { btn.style.transition = ''; }, 400);
      });
      btn.addEventListener('mouseenter', () => {
        btn.style.transition = 'none';
      });
    });

    // Mascot interactions
    document.querySelectorAll('.time-slot').forEach(function(s){
      s.addEventListener('click', function(){
        var c = document.querySelector('.mascot-toggle');
        if(c){ c.checked = true; setTimeout(function(){ c.checked = false }, 3000) }
      });
    });
    var bubbleLink = document.querySelector('.bubble-link');
    if(bubbleLink) {
      bubbleLink.addEventListener('click', function(e){
        var toggle = document.querySelector('.mascot-toggle');
        if(toggle && toggle.checked){
          window.open('https://calendar.app.google/Jxg7er6LkiL6tGEw6','_blank');
        }
        e.stopPropagation();
      });
    }
    var mascotToggle = document.querySelector('.mascot-toggle');
    if(mascotToggle){
      mascotToggle.addEventListener('change', function(){
        if(this.checked){ setTimeout(function(){ mascotToggle.checked = false }, 3000) }
      });
    }
    // Mobile mascot viewBox
    if(window.innerWidth < 768){
      var catSvg = document.querySelector('.mascot-wrap svg');
      if(catSvg) catSvg.setAttribute('viewBox','20 70 360 240');
    }

    // =============================================
    // SPIDER-WEB CARDS — Hero, Stats & Services
    // Unified system with zoom-safe rebuild
    // =============================================
    (function() {
      if (window.innerWidth < 768) return;

      var sections = document.querySelectorAll('.hero, .stats-bar, .services');
      sections.forEach(function(section) {
        var cards = section.querySelectorAll('.web-card');
        if (!cards.length) return;

        var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1;';
        section.appendChild(svg);

        // Use section dimensions for stable coordinates
        function getSectionSize() {
          return { w: section.offsetWidth, h: section.offsetHeight };
        }
        var dims = getSectionSize();
        var sw = dims.w, sh = dims.h;

        // Get card center relative to section using offset (layout-based, ignores transforms/scroll/zoom)
        function getCardCenter(card) {
          return {
            x: card.offsetLeft + card.offsetWidth / 2,
            y: card.offsetTop + card.offsetHeight / 2
          };
        }

        // Build anchors — spread across full section but denser near content area
        function buildAnchors() {
          var a = [];
          // Edge anchors (full width)
          for (var i = 0; i <= 8; i++) a.push({ x: i / 8 * sw, y: 0 });
          for (var i = 0; i <= 8; i++) a.push({ x: i / 8 * sw, y: sh });
          for (var i = 1; i <= 4; i++) a.push({ x: 0, y: i / 5 * sh });
          for (var i = 1; i <= 4; i++) a.push({ x: sw, y: i / 5 * sh });
          // Interior anchors — biased toward center content area
          var contentLeft = Math.max(0, (sw - 1200) / 2);
          var contentRight = sw - contentLeft;
          for (var i = 0; i < 14; i++) {
            a.push({ x: contentLeft + Math.random() * (contentRight - contentLeft), y: 40 + Math.random() * (sh - 80) });
          }
          return a;
        }
        var anchors = buildAnchors();

        // Track if web has been revealed in this section
        var webRevealed = false;

        function makeLine(x1, y1, x2, y2, opacity, width, dash) {
          var l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          l.setAttribute('x1', x1); l.setAttribute('y1', y1);
          l.setAttribute('x2', x2); l.setAttribute('y2', y2);
          // Start invisible — revealed on first interaction
          l.setAttribute('stroke', 'rgba(109,40,217,0)');
          l.setAttribute('stroke-width', width);
          if (dash) l.setAttribute('stroke-dasharray', dash);
          l.setAttribute('stroke-linecap', 'round');
          l.style.transition = 'stroke 0.6s ease, stroke-width 0.4s ease';
          svg.appendChild(l);
          return l;
        }

        var webData = [];

        // Collect static background lines for reactive glow
        var bgSvg = section.querySelector('.web-bg-svg');
        var bgLines = [];

        function initBgLines() {
          bgLines.length = 0;
          if (!bgSvg) return;
          var bgDots = bgSvg.querySelectorAll('circle');
          bgDots.forEach(function(dot) {
            if (!dot._origFill) dot._origFill = dot.getAttribute('fill');
            dot.setAttribute('fill', webRevealed ? dot._origFill : 'rgba(109,40,217,0)');
            dot.style.transition = 'fill 0.6s ease';
          });

          var vb = bgSvg.viewBox.baseVal;
          var allBgLines = bgSvg.querySelectorAll('line');
          allBgLines.forEach(function(line) {
            var x1 = parseFloat(line.getAttribute('x1'));
            var y1 = parseFloat(line.getAttribute('y1'));
            var x2 = parseFloat(line.getAttribute('x2'));
            var y2 = parseFloat(line.getAttribute('y2'));
            var mx = (x1 + x2) / 2, my = (y1 + y2) / 2;
            var px = mx / vb.width * sw;
            var py = my / vb.height * sh;
            if (!line._origStroke) line._origStroke = line.getAttribute('stroke');
            if (!line._origWidth) line._origWidth = line.getAttribute('stroke-width');
            line.setAttribute('stroke', webRevealed ? line._origStroke : 'rgba(109,40,217,0)');
            line.style.transition = 'stroke 0.6s ease, stroke-width 0.4s ease';
            bgLines.push({
              el: line,
              px: px, py: py,
              origStroke: line._origStroke,
              origWidth: line._origWidth
            });
          });
        }

        // Build card web lines (card-to-anchor + card-to-card)
        function buildWebLines() {
          // Remove old dynamic lines from SVG
          while (svg.firstChild) svg.removeChild(svg.firstChild);

          webData.length = 0;

          cards.forEach(function(card) {
            card.style.pointerEvents = 'auto';
            card.style.cursor = 'grab';
            card.style.zIndex = '3';
            card.style.userSelect = 'none';
            // Restore idle animation (may have been killed by prior drag)
            card.style.animation = '';
            card.style.transform = '';

            // offsetLeft/offsetTop give layout position, ignoring transforms/animations
            var center = getCardCenter(card);
            var cx = center.x, cy = center.y;

            // Pick 7-10 nearest anchors
            var sorted = anchors.map(function(a) {
              var d = Math.sqrt((a.x - cx) * (a.x - cx) + (a.y - cy) * (a.y - cy));
              return { ax: a.x, ay: a.y, dist: d };
            }).sort(function(a, b) { return a.dist - b.dist; });

            var count = 7 + Math.floor(Math.random() * 4);
            var myAnchors = sorted.slice(0, count);

            var lines = [];
            myAnchors.forEach(function(a) {
              var op = (0.05 + Math.random() * 0.08).toFixed(2);
              var w = (0.4 + Math.random() * 0.8).toFixed(1);
              var dash = Math.random() > 0.4 ? (3 + Math.floor(Math.random() * 4)) + ',' + (2 + Math.floor(Math.random() * 3)) : '';
              var el = makeLine(a.ax, a.ay, cx, cy, op, w, dash);
              // If web already revealed, show line immediately
              if (webRevealed) el.setAttribute('stroke', 'rgba(109,40,217,' + op + ')');
              lines.push({ el: el, ax: a.ax, ay: a.ay, baseOp: parseFloat(op), baseW: parseFloat(w) });
            });

            webData.push({ card: card, origX: cx, origY: cy, curX: cx, curY: cy, lines: lines });
          });

          // Card-to-card connections
          for (var i = 0; i < webData.length; i++) {
            for (var j = i + 1; j < webData.length; j++) {
              var a = webData[i], b = webData[j];
              var d = Math.sqrt(Math.pow(a.origX - b.origX, 2) + Math.pow(a.origY - b.origY, 2));
              if (d < sw * 0.7) {
                var op = (0.04 + Math.random() * 0.06).toFixed(2);
                var el = makeLine(a.origX, a.origY, b.origX, b.origY, op, '0.5', '5,3');
                if (webRevealed) el.setAttribute('stroke', 'rgba(109,40,217,' + op + ')');
                a.lines.push({ el: el, ax: b.origX, ay: b.origY, baseOp: parseFloat(op), baseW: 0.5, linked: j });
                b.lines.push({ el: el, ax: a.origX, ay: a.origY, baseOp: parseFloat(op), baseW: 0.5, linked: i, isEnd1: true });
              }
            }
          }
        }

        initBgLines();
        buildWebLines();

        // Glow nearby static bg lines when dragging
        var GLOW_RADIUS = 250; // px radius of influence
        function glowBgLines(cardX, cardY, dragDist) {
          var intensity = Math.min(dragDist / 60, 1); // 0-1 based on drag distance
          bgLines.forEach(function(bl) {
            var dx = bl.px - cardX;
            var dy = bl.py - cardY;
            var dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < GLOW_RADIUS) {
              var proximity = 1 - dist / GLOW_RADIUS; // 1 = right on top, 0 = edge of radius
              var factor = proximity * intensity;
              var newOp = Math.min(0.04 + factor * 0.25, 0.3).toFixed(3);
              var newW = (parseFloat(bl.origWidth) + factor * 1.2).toFixed(1);
              bl.el.setAttribute('stroke', 'rgba(109,40,217,' + newOp + ')');
              bl.el.setAttribute('stroke-width', newW);
            }
          });
        }

        function resetBgLines() {
          bgLines.forEach(function(bl) {
            bl.el.setAttribute('stroke', bl.origStroke);
            bl.el.setAttribute('stroke-width', bl.origWidth);
          });
        }

        function updateLines(d) {
          d.lines.forEach(function(l) {
            if (l.isEnd1) {
              l.el.setAttribute('x1', d.curX); l.el.setAttribute('y1', d.curY);
            } else {
              l.el.setAttribute('x2', d.curX); l.el.setAttribute('y2', d.curY);
            }
            var ex = l.isEnd1 ? parseFloat(l.el.getAttribute('x2')) : l.ax;
            var ey = l.isEnd1 ? parseFloat(l.el.getAttribute('y2')) : l.ay;
            var sDist = Math.sqrt(Math.pow(d.curX - ex, 2) + Math.pow(d.curY - ey, 2));
            var oDist = Math.sqrt(Math.pow(d.origX - ex, 2) + Math.pow(d.origY - ey, 2));
            var tension = Math.min(sDist / Math.max(oDist, 1), 2);
            var newW = (l.baseW + tension * 0.8).toFixed(1);
            var newOp = Math.min(l.baseOp + tension * 0.12, 0.35).toFixed(2);
            l.el.setAttribute('stroke-width', newW);
            l.el.setAttribute('stroke', 'rgba(109,40,217,' + newOp + ')');
          });
        }

        // Drag interaction
        var active = null, smx = 0, smy = 0, scx = 0, scy = 0;

        // Reveal all web lines in this section (first interaction)
        function revealWeb() {
          if (webRevealed) return;
          webRevealed = true;
          // Reveal card-to-anchor and card-to-card lines
          webData.forEach(function(d) {
            d.lines.forEach(function(l) {
              l.el.setAttribute('stroke', 'rgba(109,40,217,' + l.baseOp + ')');
            });
          });
          // Reveal background lines and dots
          bgLines.forEach(function(bl) {
            bl.el.setAttribute('stroke', bl.origStroke);
          });
          if (bgSvg) {
            var bgDots = bgSvg.querySelectorAll('circle');
            bgDots.forEach(function(dot) {
              dot.setAttribute('fill', dot._origFill);
            });
          }
        }

        function onDown(e) {
          ensureBuilt();
          var t = e.touches ? e.touches[0] : e;
          for (var i = 0; i < webData.length; i++) {
            var r = webData[i].card.getBoundingClientRect();
            if (t.clientX >= r.left && t.clientX <= r.right && t.clientY >= r.top && t.clientY <= r.bottom) {
              revealWeb();
              active = webData[i];
              // Kill idle animation for drag
              active.card.style.animation = 'none';
              active.card.style.cursor = 'grabbing';
              smx = t.clientX; smy = t.clientY;
              // offsetLeft/offsetTop give true layout position (ignores animation transform)
              var freshCenter = getCardCenter(active.card);
              active.origX = freshCenter.x;
              active.origY = freshCenter.y;
              // Calculate current visual offset from the animation that was playing
              var visualRect = active.card.getBoundingClientRect();
              var sectionRect = section.getBoundingClientRect();
              active.curX = visualRect.left + visualRect.width / 2 - sectionRect.left;
              active.curY = visualRect.top + visualRect.height / 2 - sectionRect.top;
              scx = active.curX; scy = active.curY;
              // Update line endpoints
              updateLines(active);
              e.preventDefault();
              break;
            }
          }
        }

        function onMove(e) {
          if (!active) return;
          var t = e.touches ? e.touches[0] : e;
          var dx = t.clientX - smx, dy = t.clientY - smy;
          var dist = Math.sqrt(dx * dx + dy * dy);
          if (dist > 80) { dx = dx * 80 / dist; dy = dy * 80 / dist; }
          active.curX = scx + dx;
          active.curY = scy + dy;
          active.card.style.transform = 'translate(' + (active.curX - active.origX) + 'px,' + (active.curY - active.origY) + 'px)';
          updateLines(active);
          // Glow nearby background web lines
          var dragDist = Math.sqrt(Math.pow(active.curX - active.origX, 2) + Math.pow(active.curY - active.origY, 2));
          glowBgLines(active.curX, active.curY, dragDist);
          e.preventDefault();
        }

        function onUp() {
          if (!active) return;
          active.card.style.cursor = 'grab';
          var c = active; active = null;
          var vx = 0, vy = 0;
          (function bounce() {
            var dx = c.origX - c.curX, dy = c.origY - c.curY;
            vx = (vx + dx * 0.15) * 0.75;
            vy = (vy + dy * 0.15) * 0.75;
            c.curX += vx; c.curY += vy;
            c.card.style.transform = 'translate(' + (c.curX - c.origX) + 'px,' + (c.curY - c.origY) + 'px)';
            updateLines(c);
            // Fade bg lines back as card bounces back
            var bDist = Math.sqrt(Math.pow(c.curX - c.origX, 2) + Math.pow(c.curY - c.origY, 2));
            if (bDist > 1) {
              glowBgLines(c.curX, c.curY, bDist);
            }
            if (Math.abs(dx) > 0.3 || Math.abs(dy) > 0.3 || Math.abs(vx) > 0.3 || Math.abs(vy) > 0.3) {
              requestAnimationFrame(bounce);
            } else {
              c.curX = c.origX; c.curY = c.origY;
              c.card.style.transform = '';
              // Restore idle animation
              c.card.style.animation = '';
              updateLines(c);
              resetBgLines();
            }
          })();
        }

        section.addEventListener('mousedown', onDown);
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseup', onUp);
        section.addEventListener('touchstart', onDown, { passive: false });
        window.addEventListener('touchmove', onMove, { passive: false });
        window.addEventListener('touchend', onUp);

        // On resize (zoom change): tear down everything, rebuild on next interaction
        var needsRebuild = false;
        var resizeTimer;
        window.addEventListener('resize', function() {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(function() {
            active = null;
            webRevealed = false;
            // Remove all dynamic lines
            while (svg.firstChild) svg.removeChild(svg.firstChild);
            webData.length = 0;
            // Hide bg lines and dots
            if (bgSvg) {
              bgSvg.querySelectorAll('line').forEach(function(line) {
                line.setAttribute('stroke', 'rgba(109,40,217,0)');
              });
              bgSvg.querySelectorAll('circle').forEach(function(dot) {
                dot.setAttribute('fill', 'rgba(109,40,217,0)');
              });
            }
            bgLines.length = 0;
            // Mark for lazy rebuild on next interaction
            needsRebuild = true;
          }, 150);
        });

        function ensureBuilt() {
          if (!needsRebuild) return;
          needsRebuild = false;
          var newDims = getSectionSize();
          sw = newDims.w; sh = newDims.h;
          var newAnchors = buildAnchors();
          anchors.length = 0;
          newAnchors.forEach(function(a) { anchors.push(a); });
          initBgLines();
          buildWebLines();
        }
      });
    })();
  </script>

  <!-- Service cards drag-to-swap -->
  <script is:inline>
    (function() {
      var list = document.querySelector('.services-list');
      if (!list) return;
      var rows = function() { return Array.from(list.querySelectorAll('.service-row')); };
      var dragged = null;
      var dragClone = null;
      var startY = 0;
      var startX = 0;
      var dragRect = null;
      var placeholder = null;

      function getPointer(e) {
        var t = e.touches ? e.touches[0] : e;
        return { x: t.clientX, y: t.clientY };
      }

      function onDown(e) {
        var row = e.target.closest('.service-row');
        if (!row || !list.contains(row)) return;
        var p = getPointer(e);
        startX = p.x; startY = p.y;
        dragged = row;
        dragRect = row.getBoundingClientRect();

        // Wait a tiny bit to distinguish click from drag
        dragged._mayDrag = true;
        dragged._startP = p;
      }

      function startDrag() {
        if (!dragged) return;
        var row = dragged;
        dragRect = row.getBoundingClientRect();

        // Create placeholder to keep space
        placeholder = document.createElement('div');
        placeholder.style.height = dragRect.height + 'px';
        placeholder.style.transition = 'height 0.2s ease';
        placeholder.style.pointerEvents = 'none';
        placeholder.className = 'drag-placeholder';
        row.parentNode.insertBefore(placeholder, row);

        // Style the dragged card
        row.style.position = 'fixed';
        row.style.top = dragRect.top + 'px';
        row.style.left = dragRect.left + 'px';
        row.style.width = dragRect.width + 'px';
        row.style.zIndex = '9999';
        row.style.transition = 'transform 0.05s ease, box-shadow 0.2s ease';
        row.style.boxShadow = '0 20px 60px rgba(109,40,217,0.15)';
        row.style.transform = 'scale(1.02)';
        row.style.cursor = 'grabbing';
        row.classList.add('is-dragging');
        document.body.style.userSelect = 'none';
      }

      function onMove(e) {
        if (!dragged) return;
        var p = getPointer(e);

        // Start drag after 5px movement
        if (dragged._mayDrag) {
          var dist = Math.sqrt(Math.pow(p.x - dragged._startP.x, 2) + Math.pow(p.y - dragged._startP.y, 2));
          if (dist < 5) return;
          dragged._mayDrag = false;
