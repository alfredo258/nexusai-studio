---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Testimonials from '../components/Testimonials.astro';
import Clients from '../components/Clients.astro';
import Calendar from '../components/Calendar.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "The Outbound Force",
  "description": "Implementamos un sistema de prospección B2B predecible para empresas. LinkedIn, Email Marketing, Meta Ads y Google Ads. +500 reuniones agendadas.",
  "url": "https://theoutboundforce.com",
  "areaServed": ["Argentina", "LATAM", "España", "USA"],
  "serviceType": ["Prospección B2B", "Generación de Leads", "Email Marketing", "LinkedIn Outreach", "Meta Ads", "Google Ads", "Landing Pages"],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "5"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Rosario",
    "addressRegion": "Santa Fe",
    "addressCountry": "Argentina"
  }
};
---

<Layout
  title="The Outbound Force — Prospección B2B que llena tu agenda de reuniones"
  description="Implementamos un sistema de prospección B2B predecible para empresas. LinkedIn, Email Marketing, Meta Ads y Google Ads. +500 reuniones agendadas. Agendá tu llamada gratis."
>
  <JsonLd data={serviceSchema} />
  <Header />
  <main>
    <Hero />
    <Stats />
    <Services />
    <Process />
    <Testimonials />
    <Clients />
    <FAQ />
    <Calendar />
  </main>
  <Footer />

  <!-- Scripts -->
  <script is:inline>
    // Scroll reveal observer
    const allR = document.querySelectorAll(".reveal,.reveal-left,.reveal-right,.reveal-scale");
    const rObs = new IntersectionObserver((e) => {
      e.forEach((e) => { e.isIntersecting && e.target.classList.add("active"); });
    }, { threshold: 0.08, rootMargin: "0px 0px -40px 0px" });
    allR.forEach((e) => rObs.observe(e));

    // Nav scroll effect
    window.addEventListener("scroll", () => {
      document.getElementById("navbar").classList.toggle("scrolled", window.scrollY > 50);
    });

    // Mobile menu
    document.getElementById("menuToggle").addEventListener("click", () => {
      document.getElementById("navLinks").classList.toggle("open");
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach((e) => {
      e.addEventListener("click", (t) => {
        t.preventDefault();
        const n = document.querySelector(e.getAttribute("href"));
        n && (n.scrollIntoView({ behavior: "smooth", block: "start" }),
          document.getElementById("navLinks").classList.remove("open"));
      });
    });

    // Slot counter animation
    const slotCounters = document.querySelectorAll(".slot-counter");
    const slotObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.dataset.target);
        const prefix = el.dataset.prefix || "";
        const fps = 1000 / 60;
        const totalFrames = Math.round(2000 / fps);
        let frame = 0;
        const timer = setInterval(() => {
          frame++;
          const progress = 1 - Math.pow(1 - frame / totalFrames, 4);
          el.textContent = prefix + Math.round(target * progress);
          if (frame === totalFrames) clearInterval(timer);
        }, fps);
        slotObs.unobserve(el);
      });
    }, { threshold: 0.5 });
    slotCounters.forEach((e) => slotObs.observe(e));

    // Active nav indicator on scroll
    const navSections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
    const navObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach(link => {
            link.classList.toggle('nav-active', link.getAttribute('href') === '#' + id);
          });
        }
      });
    }, { threshold: 0.3, rootMargin: '-80px 0px -50% 0px' });
    navSections.forEach(s => navObs.observe(s));

    // Parallax floating elements
    document.addEventListener("mousemove", (e) => {
      const els = document.querySelectorAll(".float-el");
      const mx = 20 * (e.clientX / window.innerWidth - 0.5);
      const my = 20 * (e.clientY / window.innerHeight - 0.5);
      els.forEach((el, i) => {
        const factor = 0.4 * (i + 1);
        el.style.transform = `translate(${mx * factor}px,${my * factor}px)`;
      });
    });

    // === MAGNETIC BUTTONS ===
    document.querySelectorAll('.magnetic-btn').forEach(btn => {
      const strength = 0.3;
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        btn.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = 'translate(0, 0)';
        btn.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
        setTimeout(() => { btn.style.transition = ''; }, 400);
      });
      btn.addEventListener('mouseenter', () => {
        btn.style.transition = 'none';
      });
    });

    // Mascot interactions
    document.querySelectorAll('.time-slot').forEach(function(s){
      s.addEventListener('click', function(){
        var c = document.querySelector('.mascot-toggle');
        if(c){ c.checked = true; setTimeout(function(){ c.checked = false }, 3000) }
      });
    });
    var bubbleLink = document.querySelector('.bubble-link');
    if(bubbleLink) {
      bubbleLink.addEventListener('click', function(e){
        var toggle = document.querySelector('.mascot-toggle');
        if(toggle && toggle.checked){
          window.open('https://calendar.app.google/Jxg7er6LkiL6tGEw6','_blank');
        }
        e.stopPropagation();
      });
    }
    var mascotToggle = document.querySelector('.mascot-toggle');
    if(mascotToggle){
      mascotToggle.addEventListener('change', function(){
        if(this.checked){ setTimeout(function(){ mascotToggle.checked = false }, 3000) }
      });
    }
    // Mobile mascot viewBox
    if(window.innerWidth < 768){
      var catSvg = document.querySelector('.mascot-wrap svg');
      if(catSvg) catSvg.setAttribute('viewBox','20 70 360 240');
    }

    // =============================================
    // SPIDER-WEB CARDS — Draggable with web strands
    // =============================================
    (function() {
      if (window.innerWidth < 768) return; // Skip on mobile

      const hero = document.querySelector('.hero');
      const cards = document.querySelectorAll('.pipe-card');
      if (!hero || !cards.length) return;

      // Create SVG overlay for web strands
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('class', 'web-svg');
      svg.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;';
      hero.querySelector('.pipe-wrap').appendChild(svg);

      // Anchor points at edges/corners of hero
      const anchors = [
        { x: 0, y: 0 },        // top-left
        { x: 0.5, y: 0 },      // top-center
        { x: 1, y: 0 },        // top-right
        { x: 0, y: 0.5 },      // mid-left
        { x: 1, y: 0.5 },      // mid-right
        { x: 0, y: 1 },        // bottom-left
        { x: 0.5, y: 1 },      // bottom-center
        { x: 1, y: 1 },        // bottom-right
      ];

      const webData = []; // Store card data

      cards.forEach(function(card, i) {
        // Stop float-drift animation so drag works
        card.style.animation = 'none';
        card.style.pointerEvents = 'auto';
        card.style.cursor = 'grab';
        card.style.zIndex = '3';
        card.style.position = 'absolute';
        card.style.userSelect = 'none';
        card.style.transition = 'none';
        card.style.opacity = '1';
        card.style.clipPath = 'none';

        const rect = card.getBoundingClientRect();
        const heroRect = hero.getBoundingClientRect();
        const cx = rect.left + rect.width / 2 - heroRect.left;
        const cy = rect.top + rect.height / 2 - heroRect.top;
        const hw = heroRect.width;
        const hh = heroRect.height;

        // Pick 2-3 nearest anchors for each card
        const anchorPts = anchors.map(function(a) {
          var ax = a.x * hw, ay = a.y * hh;
          var dist = Math.sqrt((ax - cx) * (ax - cx) + (ay - cy) * (ay - cy));
          return { ax: ax, ay: ay, dist: dist };
        });
        anchorPts.sort(function(a, b) { return a.dist - b.dist; });
        var myAnchors = anchorPts.slice(0, 3);

        // Create web strand lines
        var lines = [];
        myAnchors.forEach(function(anchor) {
          var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('x1', anchor.ax);
          line.setAttribute('y1', anchor.ay);
          line.setAttribute('x2', cx);
          line.setAttribute('y2', cy);
          line.setAttribute('stroke', 'rgba(109,40,217,0.12)');
          line.setAttribute('stroke-width', '1');
          line.setAttribute('stroke-dasharray', '4,3');
          svg.appendChild(line);
          lines.push({ el: line, ax: anchor.ax, ay: anchor.ay });
        });

        webData.push({
          card: card,
          origX: cx,
          origY: cy,
          curX: cx,
          curY: cy,
          lines: lines,
          dragging: false,
          velX: 0,
          velY: 0,
        });
      });

      // Drag logic
      var activeCard = null;
      var startMX = 0, startMY = 0, startCX = 0, startCY = 0;

      function onDown(e) {
        var touch = e.touches ? e.touches[0] : e;
        var heroRect = hero.getBoundingClientRect();
        for (var i = 0; i < webData.length; i++) {
          var d = webData[i];
          var cardRect = d.card.getBoundingClientRect();
          if (touch.clientX >= cardRect.left && touch.clientX <= cardRect.right &&
              touch.clientY >= cardRect.top && touch.clientY <= cardRect.bottom) {
            activeCard = d;
            d.dragging = true;
            d.card.style.cursor = 'grabbing';
            startMX = touch.clientX;
            startMY = touch.clientY;
            startCX = d.curX;
            startCY = d.curY;
            e.preventDefault();
            break;
          }
        }
      }

      function onMove(e) {
        if (!activeCard) return;
        var touch = e.touches ? e.touches[0] : e;
        var dx = touch.clientX - startMX;
        var dy = touch.clientY - startMY;

        // Limit drag range (web tension)
        var maxDist = 80;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > maxDist) {
          dx = dx * maxDist / dist;
          dy = dy * maxDist / dist;
        }

        activeCard.curX = startCX + dx;
        activeCard.curY = startCY + dy;

        var offX = activeCard.curX - activeCard.origX;
        var offY = activeCard.curY - activeCard.origY;
        activeCard.card.style.transform = 'translate(' + offX + 'px,' + offY + 'px)';

        // Update web strands
        activeCard.lines.forEach(function(l) {
          l.el.setAttribute('x2', activeCard.curX);
          l.el.setAttribute('y2', activeCard.curY);
          // Thicker when stretched
          var sDist = Math.sqrt(Math.pow(activeCard.curX - l.ax, 2) + Math.pow(activeCard.curY - l.ay, 2));
          var origDist = Math.sqrt(Math.pow(activeCard.origX - l.ax, 2) + Math.pow(activeCard.origY - l.ay, 2));
          var tension = Math.min(sDist / origDist, 1.5);
          l.el.setAttribute('stroke-width', (0.8 + tension * 0.8).toFixed(1));
          l.el.setAttribute('stroke', 'rgba(109,40,217,' + (0.08 + tension * 0.15).toFixed(2) + ')');
        });

        e.preventDefault();
      }

      function onUp() {
        if (!activeCard) return;
        activeCard.dragging = false;
        activeCard.card.style.cursor = 'grab';

        // Spring back animation
        var card = activeCard;
        activeCard = null;

        var spring = 0.15;
        var damping = 0.75;
        var velX = 0, velY = 0;

        function animate() {
          var dx = card.origX - card.curX;
          var dy = card.origY - card.curY;

          velX += dx * spring;
          velY += dy * spring;
          velX *= damping;
          velY *= damping;

          card.curX += velX;
          card.curY += velY;

          var offX = card.curX - card.origX;
          var offY = card.curY - card.origY;
          card.card.style.transform = 'translate(' + offX + 'px,' + offY + 'px)';

          // Update web strands
          card.lines.forEach(function(l) {
            l.el.setAttribute('x2', card.curX);
            l.el.setAttribute('y2', card.curY);
            var sDist = Math.sqrt(Math.pow(card.curX - l.ax, 2) + Math.pow(card.curY - l.ay, 2));
            var origDist = Math.sqrt(Math.pow(card.origX - l.ax, 2) + Math.pow(card.origY - l.ay, 2));
            var tension = Math.min(sDist / origDist, 1.5);
            l.el.setAttribute('stroke-width', (0.8 + tension * 0.8).toFixed(1));
            l.el.setAttribute('stroke', 'rgba(109,40,217,' + (0.08 + tension * 0.15).toFixed(2) + ')');
          });

          if (Math.abs(dx) > 0.3 || Math.abs(dy) > 0.3 || Math.abs(velX) > 0.3 || Math.abs(velY) > 0.3) {
            requestAnimationFrame(animate);
          } else {
            card.curX = card.origX;
            card.curY = card.origY;
            card.card.style.transform = 'translate(0,0)';
            card.lines.forEach(function(l) {
              l.el.setAttribute('x2', card.origX);
              l.el.setAttribute('y2', card.origY);
              l.el.setAttribute('stroke-width', '1');
              l.el.setAttribute('stroke', 'rgba(109,40,217,0.12)');
            });
          }
        }
        requestAnimationFrame(animate);
      }

      hero.addEventListener('mousedown', onDown);
      window.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onUp);
      hero.addEventListener('touchstart', onDown, { passive: false });
      window.addEventListener('touchmove', onMove, { passive: false });
      window.addEventListener('touchend', onUp);
    })();
  </script>

  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-V0C9DB2TVB"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag("js", new Date());
    gtag("config", "G-V0C9DB2TVB");
  </script>
</Layout>
