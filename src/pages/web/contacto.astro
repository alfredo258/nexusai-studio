  /* Desactivar el m-float (cat flotando arriba/abajo) — acá la PC está
     APOYADA sobre el escritorio, no debería flotar. */
  animation: none !important;
}

/* Tablet+laptop range: gato un poco más chico */
@media (max-width: 1600px) and (min-width: 901px) {
