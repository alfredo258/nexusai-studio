        <ellipse cx="150" cy="174" rx="30" ry="26" fill="#d4c8f0" opacity=".25"/>
        <g class="eyes-closed"><path d="M132 168q6 4 12 0" stroke="#3d2014" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M157 168q6 4 12 0" stroke="#3d2014" stroke-width="2" fill="none" stroke-linecap="round"/><line x1="131" y1="168" x2="129" y2="165" stroke="#3d2014" stroke-width="1" stroke-linecap="round"/><line x1="156" y1="168" x2="154" y2="165" stroke="#3d2014" stroke-width="1" stroke-linecap="round"/></g>
        <g class="eyes-open"><g class="pupil-group"><ellipse cx="138" cy="166" rx="8" ry="9" fill="#fff"/><circle cx="138" cy="167" r="5.5" fill="#4a2810"/><circle cx="138" cy="167" r="3.5" fill="#111"/><circle cx="140" cy="164.5" r="2" fill="#fff" class="eye-sparkle"/><circle cx="136" cy="168" r="1" fill="#fff" opacity=".4" class="eye-sparkle"/><ellipse cx="163" cy="166" rx="8" ry="9" fill="#fff"/><circle cx="163" cy="167" r="5.5" fill="#4a2810"/><circle cx="163" cy="167" r="3.5" fill="#111"/><circle cx="165" cy="164.5" r="2" fill="#fff" class="eye-sparkle"/><circle cx="161" cy="168" r="1" fill="#fff" opacity=".4" class="eye-sparkle"/></g><path d="M128 162q2-3 4-1" stroke="#3d2014" stroke-width="1" fill="none"/><path d="M130 160q2-2 3 0" stroke="#3d2014" stroke-width=".8" fill="none"/><path d="M168 160q2-2 3 0" stroke="#3d2014" stroke-width=".8" fill="none"/><path d="M170 162q2-3 4-1" stroke="#3d2014" stroke-width="1" fill="none"/><path d="M130 158q4-3 8 0" stroke="#9580cc" stroke-width="1.2" fill="none" opacity=".4"/><path d="M155 158q4-3 8 0" stroke="#9580cc" stroke-width="1.2" fill="none" opacity=".4"/></g>
        <g class="glasses-group"><circle cx="138" cy="167" r="12" fill="none" stroke="#555" stroke-width="2"/><circle cx="138" cy="167" r="12" fill="#88f" opacity=".03"/><circle cx="163" cy="167" r="12" fill="none" stroke="#555" stroke-width="2"/><circle cx="163" cy="167" r="12" fill="#88f" opacity=".03"/><path d="M150 167q0-3 1 0" stroke="#555" stroke-width="2" fill="none"/><line x1="126" y1="165" x2="115" y2="160" stroke="#555" stroke-width="1.5" stroke-linecap="round"/><line x1="175" y1="165" x2="186" y2="160" stroke="#555" stroke-width="1.5" stroke-linecap="round"/><path d="M131 162q2-3 5-1" stroke="#fff" stroke-width=".8" fill="none" opacity=".15"/><path d="M156 162q2-3 5-1" stroke="#fff" stroke-width=".8" fill="none" opacity=".15"/></g>
