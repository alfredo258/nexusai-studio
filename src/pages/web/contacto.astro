---
import Layout from '../../layouts/Layout.astro';
import ContactBackground from '../../components/ContactBackground.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import Footer from '../../components/Footer.astro';
---
<Layout title="Agendá tu llamada gratis — Diagnóstico de prospección B2B | TOF" description="30 minutos sin compromiso: diagnosticamos tu prospección, detectamos oportunidades concretas y te mostramos cómo triplicar reuniones en 90 días.">

<ContactBackground />

<nav id="navbar">
  <div class="nav-inner">
    <a href="/web/" class="nav-logo">The Outbound <span>Force</span></a>
    <div class="nav-links" id="navLinks">
      <a href="/web/">Inicio</a>
      <a href="/web/outbound">Outbound</a>
      <a href="/web/desarrollo-web">Desarrollo Web</a>
      <a href="/web/faq">FAQ</a>
      <a href="/web/contacto" class="nav-active">Contacto</a>
      <ThemeToggle />
      <a href="https://calendar.app.google/Jxg7er6LkiL6tGEw6" class="nav-cta magnetic-btn" rel="noopener" target="_blank">Agendar Reunión</a>
    </div>
    <button aria-label="Menú" class="menu-toggle" id="menuToggle"><span></span><span></span><span></span></button>
  </div>
</nav>

<main id="main-content" tabindex="-1">
  <div style="height: 4.5rem;"></div>

  <section class="ct-section">
    <div class="container">
      <div class="ct-grid">

        <!-- LEFT: Info -->
        <div class="ct-left">
          <span class="ct-kicker">Contacto</span>
          <h1 class="ct-title">30 minutos para encontrar <em>dónde está el cuello de botella.</em></h1>
          <p class="ct-subtitle">Contanos sobre tu negocio y en menos de 24 horas te respondemos con un diagnóstico preliminar + 3 oportunidades concretas que podés accionar (hayamos trabajado juntos o no).</p>

          <div class="ct-trust">
            <div class="ct-trust-avatars" aria-hidden="true">
              <img src="/assets/images/avatar-tomas.png" alt="Tomás — TOF" width="30" height="30" loading="eager" />
              <img src="/assets/images/avatar-sebastian.png" alt="Sebastián — TOF" width="30" height="30" loading="eager" />
              <img src="/assets/images/avatar-jorge.png" alt="Jorge — TOF" width="30" height="30" loading="eager" />
              <img src="/assets/images/avatar-sandra.png" alt="Sandra — TOF" width="30" height="30" loading="eager" />
            </div>
            <div class="ct-trust-text">
              <div class="ct-trust-stars">★★★★★</div>
              <span>Respuesta promedio <strong>menos de 24h</strong></span>
            </div>
          </div>

          <!-- Contact cards -->
          <div class="ct-cards">
            <a href="mailto:alfredo@theoutboundforce.com" class="ct-card">
              <div class="ct-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <span class="ct-card-label">Email</span>
                <span class="ct-card-value">alfredo@theoutboundforce.com</span>
              </div>
            </a>
            <a href="https://www.linkedin.com/company/the-outbound-force" target="_blank" rel="noopener" class="ct-card">
              <div class="ct-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.064 2.064 0 110-4.128 2.064 2.064 0 010 4.128zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg>
              </div>
              <div>
                <span class="ct-card-label">LinkedIn</span>
                <span class="ct-card-value">the-outbound-force</span>
              </div>
            </a>
            <a href="https://calendar.app.google/Jxg7er6LkiL6tGEw6" target="_blank" rel="noopener" class="ct-card">
              <div class="ct-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect height="18" rx="2" width="18" x="3" y="4"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
              </div>
              <div>
                <span class="ct-card-label">Agenda directa</span>
                <span class="ct-card-value">Elegí tu horario</span>
              </div>
            </a>
          </div>
        </div>

        <!-- RIGHT: Form card + Cat -->
        <div class="ct-right">
          <div class="ct-form-card">
            <form class="ct-form" name="contacto-tof" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="ct-multistep">
              <input type="hidden" name="form-name" value="contacto-tof" />
              <p class="hidden" style="display:none;"><label>No llenar: <input name="bot-field" /></label></p>

              <!-- STEP 1 -->
              <div class="ct-step active" data-step="0">
                <div class="ct-form-dot"></div>
                <p class="ct-form-step">Paso 1 de 4: Contanos de vos</p>
                <h2 class="ct-form-title">¡Hola! Empecemos por presentarnos.</h2>
                <p class="ct-form-sub">¿Cómo te llamás y de qué empresa nos visitás?</p>
                <div class="ct-fields">
                  <label class="ct-label">Nombre completo
                    <input type="text" name="nombre" class="ct-input" placeholder="Tu nombre" required autocomplete="name" />
                  </label>
                  <label class="ct-label">Empresa
                    <input type="text" name="empresa" class="ct-input" placeholder="Nombre de tu empresa" required autocomplete="organization" />
                  </label>
                </div>
                <button type="button" class="btn btn-primary ct-next" data-next="1">Siguiente
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" height="16" width="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </button>
              </div>

              <!-- STEP 2 -->
              <div class="ct-step" data-step="1">
                <div class="ct-form-dot"></div>
                <p class="ct-form-step">Paso 2 de 4: ¿Cómo te contactamos?</p>
                <h2 class="ct-form-title">Compartinos tus datos.</h2>
                <p class="ct-form-sub">Para agendar la sesión y enviarte el diagnóstico.</p>
                <div class="ct-fields">
                  <label class="ct-label">Email
                    <input type="email" name="email" class="ct-input" placeholder="tu@empresa.com" required autocomplete="email" inputmode="email" />
                  </label>
                  <label class="ct-label">Teléfono
                    <input type="tel" name="telefono" class="ct-input" placeholder="+54 9 11 1234 5678" autocomplete="tel" inputmode="tel" />
                  </label>
                </div>
                <div class="ct-nav-buttons">
                  <button type="button" class="btn btn-ghost ct-prev" data-prev="0">Atrás</button>
                  <button type="button" class="btn btn-primary ct-next" data-next="2">Siguiente
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" height="16" width="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </button>
                </div>
              </div>

              <!-- STEP 3 -->
              <div class="ct-step" data-step="2">
                <div class="ct-form-dot"></div>
                <p class="ct-form-step">Paso 3 de 4: Sobre tu prospección</p>
                <h2 class="ct-form-title">¿Qué canal te interesa?</h2>
                <p class="ct-form-sub">Ayudanos a entender qué necesitás para asignar al especialista correcto.</p>
                <div class="ct-fields">
                  <label class="ct-label">Canal de interés
                    <select name="canal" class="ct-input ct-select" required>
                      <option value="" disabled selected>Seleccioná una opción</option>
                      <option value="LinkedIn Outreach">LinkedIn Outreach</option>
                      <option value="Email Marketing">Email Marketing</option>
                      <option value="Meta Ads">Meta Ads</option>
                      <option value="Google Ads">Google Ads</option>
                      <option value="Landing Pages">Landing Pages</option>
                      <option value="Todos">Todos los canales</option>
                      <option value="No estoy seguro">No estoy seguro</option>
                    </select>
                  </label>
                  <label class="ct-label">¿Cuántas reuniones buscás por mes?
                    <select name="reuniones" class="ct-input ct-select" required>
                      <option value="" disabled selected>Seleccioná un rango</option>
                      <option value="5-10">5 - 10 reuniones</option>
                      <option value="10-20">10 - 20 reuniones</option>
                      <option value="20-50">20 - 50 reuniones</option>
                      <option value="50+">Más de 50 reuniones</option>
                      <option value="No sé aún">Aún no lo tengo pensado</option>
                    </select>
                  </label>
                </div>
                <div class="ct-nav-buttons">
                  <button type="button" class="btn btn-ghost ct-prev" data-prev="1">Atrás</button>
                  <button type="button" class="btn btn-primary ct-next" data-next="3">Siguiente
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" height="16" width="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </button>
                </div>
              </div>

              <!-- STEP 4 -->
              <div class="ct-step" data-step="3">
                <div class="ct-form-dot"></div>
                <p class="ct-form-step">Paso 4 de 4: Detalles finales</p>
                <h2 class="ct-form-title">¿Algo más que debamos saber?</h2>
                <p class="ct-form-sub">Contanos brevemente sobre tu negocio o el desafío que querés resolver.</p>
                <div class="ct-fields">
                  <label class="ct-label">Mensaje (opcional)
                    <textarea name="mensaje" class="ct-input ct-textarea" placeholder="Describí tu proyecto o reto brevemente..." rows="4"></textarea>
                  </label>
                </div>
                <div class="ct-nav-buttons">
                  <button type="button" class="btn btn-ghost ct-prev" data-prev="2">Atrás</button>
                  <button type="submit" class="btn btn-primary ct-submit">Enviar mensaje
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" height="16" width="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </button>
                </div>
              </div>

              <!-- SUCCESS -->
              <div class="ct-step ct-success" data-step="4">
                <div class="ct-success-icon">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6d28d9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <h2 class="ct-form-title">¡Mensaje recibido!</h2>
                <p class="ct-form-sub">Gracias por confiar en The Outbound Force. Nuestro equipo te contactará en menos de 24 horas.</p>
                <a href="https://calendar.app.google/Jxg7er6LkiL6tGEw6" class="btn btn-primary" target="_blank" rel="noopener">Agendar reunión ahora
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" height="16" width="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>

            </form>
          </div>

          <!-- MASCOT CAT — identical to Calendar.astro original -->
          <div class="ct-mascot">
          <label class="mascot-wrap" style="width:250px;height:240px;opacity:.95;pointer-events:auto;cursor:pointer;display:block;">
            <input type="checkbox" class="mascot-toggle"/>
            <svg viewBox="10 70 400 240" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;overflow:visible">
      <!-- Desk propio del componente removido — el gato/PC ahora se sienta sobre
           el desk del ContactBackground, sin doble escritorio. -->
      <!-- (rects originales: x=20 y=230 w=280 h=70 fill=#1a1a2e + edge highlight) -->
      <rect x="85" y="85" width="150" height="110" rx="8" fill="#252540"/>
      <rect x="80" y="80" width="160" height="115" rx="10" fill="#2d2d50"/>
      <rect x="90" y="90" width="140" height="95" rx="6" fill="#0e0e1a"/>
      <ellipse cx="160" cy="137" rx="55" ry="35" fill="#6d28d9" class="monitor-light"/>
      <g class="screen-content">
        <rect x="100" y="102" width="45" height="3" rx="1.5" fill="#8b5cf6"/>
        <rect x="100" y="110" width="65" height="3" rx="1.5" fill="#6d28d9"/>
        <rect x="100" y="118" width="35" height="3" rx="1.5" fill="#a78bfa"/>
        <rect x="100" y="126" width="55" height="3" rx="1.5" fill="#7c3aed"/>
        <rect x="100" y="134" width="40" height="3" rx="1.5" fill="#8b5cf6"/>
        <rect x="100" y="142" width="70" height="3" rx="1.5" fill="#6d28d9"/>
        <rect x="100" y="150" width="30" height="3" rx="1.5" fill="#a78bfa"/>
        <rect x="100" y="158" width="50" height="3" rx="1.5" fill="#7c3aed"/>
        <rect x="100" y="166" width="60" height="3" rx="1.5" fill="#8b5cf6"/>
        <rect x="100" y="174" width="2" height="8" rx="1" fill="#a78bfa" opacity=".6"><animate attributeName="opacity" values=".6;0;.6" dur="1.2s" repeatCount="indefinite"/></rect>
      </g>
      <rect x="145" y="195" width="30" height="18" rx="3" fill="#2d2d50"/>
      <rect x="130" y="210" width="60" height="8" rx="4" fill="#2d2d50"/>
      <rect x="65" y="222" width="190" height="20" rx="4" fill="#2a2a48"/>
      <rect x="68" y="224" width="184" height="16" rx="3" fill="#1f1f3a"/>
      <g opacity=".35"><rect x="73" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="83" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="93" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="103" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="113" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="123" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="133" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="143" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="153" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="163" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="173" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="183" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="193" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="203" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="213" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="223" y="226" width="8" height="4" rx="1" fill="#555"/><rect x="233" y="226" width="12" height="4" rx="1" fill="#555"/><rect x="75" y="232" width="12" height="4" rx="1" fill="#555"/><rect x="90" y="232" width="8" height="4" rx="1" fill="#555"/><rect x="105" y="232" width="50" height="4" rx="1" fill="#666"/><rect x="160" y="232" width="8" height="4" rx="1" fill="#555"/><rect x="175" y="232" width="8" height="4" rx="1" fill="#555"/><rect x="190" y="232" width="8" height="4" rx="1" fill="#555"/><rect x="205" y="232" width="38" height="4" rx="1" fill="#555"/></g>
      <rect x="38" y="212" width="20" height="22" rx="3" fill="#3d2c5e"/>
      <rect x="35" y="210" width="26" height="5" rx="2.5" fill="#4a3570"/>
      <path d="M58 217q7-1 6 6t-6 5" stroke="#3d2c5e" stroke-width="3" fill="none"/>
      <path d="M45 220c0-2 2-3 3-1.5c1-1.5 3-.5 3 1.5c0 2.5-3 4-3 4s-3-1.5-3-4" fill="#8b5cf6" opacity=".5"/>
      <g class="steam"><path d="M44 207q1.5-5 3 0q1.5-4 3 0" stroke="#a78bfa" stroke-width="1" fill="none" opacity=".5"/><path d="M47 205q1-4 2 0q1-3 2 0" stroke="#a78bfa" stroke-width=".8" fill="none" opacity=".3"/></g>
      <g class="cat-body-main">
        <path d="M230 200Q260 185 268 160Q275 135 260 125Q250 118 245 128" stroke="#c4b5fd" stroke-width="10" fill="none" stroke-linecap="round" class="cat-tail"/>
        <circle cx="245" cy="128" r="5" fill="#c4b5fd" class="cat-tail"/>
        <ellipse cx="175" cy="208" rx="55" ry="28" fill="#c4b5fd"/>
        <ellipse cx="172" cy="212" rx="40" ry="20" fill="#e8e0ff" opacity=".3"/>
        <path d="M150 195q5-5 10 0" stroke="#b4a0e8" stroke-width="1.5" fill="none" opacity=".3"/>
        <path d="M165 192q5-5 10 0" stroke="#b4a0e8" stroke-width="1.5" fill="none" opacity=".3"/>
        <path d="M180 193q5-5 10 0" stroke="#b4a0e8" stroke-width="1.5" fill="none" opacity=".3"/>
        <ellipse cx="220" cy="225" rx="12" ry="7" fill="#b4a0e8"/>
        <circle cx="216" cy="226" r="2" fill="#9580cc" opacity=".3"/><circle cx="220" cy="227" r="1.5" fill="#9580cc" opacity=".3"/><circle cx="224" cy="226" r="1.5" fill="#9580cc" opacity=".3"/>
        <g class="paw-left"><ellipse cx="128" cy="222" rx="14" ry="8" fill="#b4a0e8"/><circle cx="122" cy="223" r="2.5" fill="#9580cc" opacity=".3"/><circle cx="127" cy="225" r="2" fill="#9580cc" opacity=".3"/><circle cx="132" cy="223" r="2" fill="#9580cc" opacity=".3"/><ellipse cx="128" cy="221" rx="13" ry="7" fill="#b4a0e8" class="typing-paw"/></g>
        <g class="paw-right"><ellipse cx="178" cy="222" rx="14" ry="8" fill="#b4a0e8"/><circle cx="172" cy="223" r="2.5" fill="#9580cc" opacity=".3"/><circle cx="177" cy="225" r="2" fill="#9580cc" opacity=".3"/><circle cx="182" cy="223" r="2" fill="#9580cc" opacity=".3"/><ellipse cx="178" cy="221" rx="13" ry="7" fill="#b4a0e8" class="typing-paw"/></g>
      </g>
