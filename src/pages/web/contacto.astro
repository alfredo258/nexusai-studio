<script is:inline>
  // Multi-step form logic
  (function() {
    var form = document.getElementById('ct-multistep');
    if (!form) return;
    var steps = form.querySelectorAll('.ct-step');
    var current = 0;

    function showStep(n) {
      steps.forEach(function(s, i) {
        s.classList.toggle('active', i === n);
      });
      current = n;
    }

    // Next buttons
    form.querySelectorAll('.ct-next').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var step = steps[current];
        var inputs = step.querySelectorAll('input[required], select[required]');
        var valid = true;
        inputs.forEach(function(inp) {
          if (!inp.value.trim()) { inp.focus(); valid = false; }
        });
        if (!valid) return;
        var next = parseInt(btn.getAttribute('data-next'));
        showStep(next);
      });
    });

    // Prev buttons
    form.querySelectorAll('.ct-prev').forEach(function(btn) {
      btn.addEventListener('click', function() {
        showStep(parseInt(btn.getAttribute('data-prev')));
      });
    });

    // Submit
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var formData = new FormData(form);
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData).toString()
      }).then(function() {
        showStep(4); // success
      }).catch(function() {
        showStep(4); // show success anyway, Netlify will retry
      });
    });
  })();

  // Mascot toggle
  var mascotToggle = document.querySelector('.mascot-toggle');
  if (mascotToggle) {
    mascotToggle.addEventListener('change', function() {
      if (this.checked) { setTimeout(function() { mascotToggle.checked = false; }, 3000); }
    });
  }

  var nav = document.getElementById('navbar');
  if (nav) window.addEventListener('scroll', function() { nav.classList.toggle('scrolled', window.scrollY > 50); });

  // ═══ Posicionar el gato/PC exactamente sobre el desk del ContactBackground ═══
  // bg SVG: viewBox 1600x1100 con preserveAspectRatio="xMidYMax slice"
  // → scale = max(vw/1600, vh/1100), bottom-aligned
  // Desk top en viewBox: y=730 → desk top viewport y = vh - (1100-730)*scale = vh - 370*scale
  // Cat svg viewBox 10 70 400 240. Monitor base ~ y=242 en viewBox = (242-70)/240 = 71.6% from top of wrap.
  // Para que la base del monitor (PC) caiga exactamente sobre el desk top,
  // wrap.bottom debe estar a deskTopVp + (1 - 0.716)*wrapHeight
  (function() {
    var mascot = document.querySelector('.ct-mascot');
    if (!mascot) return;
    function measureGap(wrap, vh) {
      var vw = window.innerWidth;
      var bgScale = Math.max(vw / 1600, vh / 1100);
      var deskTopVp = vh - 370 * bgScale;
      var lowestVp = -Infinity;
      wrap.querySelectorAll('rect, ellipse, circle, path').forEach(function(el) {
        var r = el.getBoundingClientRect();
        if (r.width > 0 && r.bottom > lowestVp) lowestVp = r.bottom;
      });
      return { deskTopVp: deskTopVp, lowestVp: lowestVp, gap: deskTopVp - lowestVp };
    }
    function alignCatToDesk() {
      var wrap = mascot.querySelector('.mascot-wrap');
      if (!wrap) return;
      var vw = window.innerWidth, vh = window.innerHeight;
      if (vw < 901) { mascot.style.bottom = ''; return; }
      // Iterar: medir gap entre cat-bottom y desk-top, ajustar hasta gap ≈ 0
      var currentBottom = parseFloat(getComputedStyle(mascot).bottom) || 280;
      for (var i = 0; i < 5; i++) {
        var m = measureGap(wrap, vh);
        if (m.lowestVp === -Infinity) return;
        if (Math.abs(m.gap) < 1) break;
        // Si gap > 0, cat está ABOVE desk (volando) → bajar (decrease bottom)
        currentBottom = currentBottom - m.gap - 2; // -2 para overlap mínimo de apoyo
        mascot.style.bottom = currentBottom + 'px';
      }
    }
    alignCatToDesk();
    setTimeout(alignCatToDesk, 50);
    setTimeout(alignCatToDesk, 250);
    var t;
    window.addEventListener('resize', function() {
      clearTimeout(t);
      t = setTimeout(alignCatToDesk, 100);
    });
  })();
  var menuToggle = document.getElementById('menuToggle');
  var navLinks = document.getElementById('navLinks');
  if (menuToggle && navLinks) menuToggle.addEventListener('click', function() { navLinks.classList.toggle('open'); menuToggle.classList.toggle('active'); });
  document.querySelectorAll('.magnetic-btn').forEach(function(btn) {
    btn.addEventListener('mousemove', function(e) { var r = btn.getBoundingClientRect(); btn.style.transform = 'translate(' + (e.clientX-r.left-r.width/2)*0.3 + 'px,' + (e.clientY-r.top-r.height/2)*0.3 + 'px)'; });
    btn.addEventListener('mouseleave', function() { btn.style.transform = 'translate(0,0)'; btn.style.transition = 'transform 0.4s cubic-bezier(0.34,1.56,0.64,1)'; setTimeout(function(){btn.style.transition='';},400); });
    btn.addEventListener('mouseenter', function() { btn.style.transition = 'none'; });
  });
</script>
