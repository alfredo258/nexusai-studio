        <ellipse cx="150" cy="170" rx="38" ry="34" fill="#c4b5fd"/>
        <path d="M117 148L108 115L130 140Z" fill="#c4b5fd"/><path d="M119 145L112 120L128 140Z" fill="#e8b4c8" opacity=".35"/>
        <g class="ear-right"><path d="M183 148L192 115L170 140Z" fill="#c4b5fd"/><path d="M181 145L188 120L172 140Z" fill="#e8b4c8" opacity=".35"/></g>
        <path d="M135 148q3-4 6 0" stroke="#b4a0e8" stroke-width="1.2" fill="none" opacity=".25"/>
