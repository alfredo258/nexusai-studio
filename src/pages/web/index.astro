          var sorted = anchors.map(function(a) { return { ax: a.x, ay: a.y, dist: Math.sqrt((a.x - cx) * (a.x - cx) + (a.y - cy) * (a.y - cy)) }; }).sort(function(a, b) { return a.dist - b.dist; });
          var count = 5 + Math.floor(Math.random() * 3), myAnchors = sorted.slice(0, count), lines = [];
          myAnchors.forEach(function(a) {
            var op = (0.06 + Math.random() * 0.1).toFixed(2), w = (0.5 + Math.random() * 1).toFixed(1);
            var dash = Math.random() > 0.4 ? (3 + Math.floor(Math.random() * 4)) + ',' + (2 + Math.floor(Math.random() * 3)) : '';
            lines.push({ el: makeLine(a.ax, a.ay, cx, cy, op, w, dash), ax: a.ax, ay: a.ay, baseOp: parseFloat(op), baseW: parseFloat(w) });
