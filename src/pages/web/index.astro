  <!-- Living Pipeline scroll animation -->
  <script is:inline>
    (function() {
      var section = document.getElementById('pipeline-tracker');
      if (!section) return;
      var canvas = document.getElementById('lp-scale-canvas');
      var path = document.getElementById('lp-main-route');
      var card = document.getElementById('lp-prospect');
      var nodes = section.querySelectorAll('.lp-node');
      var calSlots = section.querySelectorAll('.lp-cal-slot[data-fill]');
      var particles = [document.getElementById('lp-p1'), document.getElementById('lp-p2')];
      var pathLength = path.getTotalLength();
      var isMobile = window.innerWidth <= 768;

      function resizeCanvas() {
        var vw = window.innerWidth;
        var header = section.querySelector('.lp-header');
        var headerH = header ? header.offsetHeight : 0;
        var sticky = section.querySelector('.lp-sticky');
        if (isMobile) return;
        var scale = vw / 1920;
        canvas.style.transform = 'scale(' + scale + ')';
        canvas.style.transformOrigin = 'left top';
        var contentTop = 100, contentBottom = 770;
        var scaledContentH = (contentBottom - contentTop) * scale;
        canvas.style.marginTop = -(contentTop * scale) + 'px';
        canvas.style.marginLeft = '0px';
        sticky.style.height = (headerH + scaledContentH) + 'px';
      }
      window.addEventListener('resize', resizeCanvas);
      resizeCanvas();

      var targetProgress = 0, currentProgress = 0, locked = false, completed = false, sectionVisible = false;
      var scrollNeeded = 1800, accumulated = 0, rafId = null;

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          sectionVisible = entry.isIntersecting && entry.intersectionRatio > 0.85;
        });
      }, { threshold: [0, 0.5, 0.85, 1] });
      observer.observe(section);

      function renderPipeline(p) {
        var pathStart = 0.12;
        var mappedP = pathStart + p * (1 - pathStart);
        var currentDist = mappedP * pathLength;
        var point = path.getPointAtLength(currentDist);
        card.style.transform = 'translate(calc(' + point.x + 'px - 50%), calc(' + point.y + 'px - 50%))';
        if (p < 0.03) card.style.opacity = p / 0.03;
        else if (p > 0.95) card.style.opacity = Math.max(0, 1 - (p - 0.95) * 20);
        else card.style.opacity = 1;
        particles.forEach(function(par, i) {
          var d = Math.max(0, currentDist - (20 + i * 15));
          var pp = path.getPointAtLength(d);
          par.style.transform = 'translate(calc(' + pp.x + 'px - 50%), calc(' + pp.y + 'px - 50%))';
          par.style.opacity = p > 0.05 && p < 0.92 ? 0.5 - i * 0.15 : 0;
        });
        nodes.forEach(function(node) {
          var nx = parseInt(node.style.left), ny = parseInt(node.style.top);
          var dist = Math.hypot(point.x - nx, point.y - ny);
          node.classList.toggle('active', dist < 180);
        });
        calSlots.forEach(function(slot) {
          var trigger = parseFloat(slot.getAttribute('data-fill'));
          if (trigger < 1) slot.classList.toggle('filled', p > trigger);
        });
      }

      function animate() {
        var diff = targetProgress - currentProgress;
        if (Math.abs(diff) > 0.0005) {
          currentProgress += diff * 0.12;
          renderPipeline(currentProgress);
          rafId = requestAnimationFrame(animate);
        } else { currentProgress = targetProgress; renderPipeline(currentProgress); rafId = null; }
      }

      function setProgress(p) {
        targetProgress = Math.max(0, Math.min(1, p));
        if (!rafId) rafId = requestAnimationFrame(animate);
      }

      function handleDelta(deltaY) {
        if (!sectionVisible) return false;
        if (!locked && deltaY > 0 && targetProgress < 1 && !completed) { locked = true; accumulated = targetProgress * scrollNeeded; }
        if (!locked && deltaY < 0 && targetProgress > 0 && completed) { locked = true; accumulated = targetProgress * scrollNeeded; completed = false; }
        if (!locked) return false;
        accumulated += deltaY;
        accumulated = Math.max(0, Math.min(scrollNeeded, accumulated));
        setProgress(accumulated / scrollNeeded);
        if (accumulated >= scrollNeeded) { locked = false; completed = true; }
        if (accumulated <= 0) { locked = false; completed = false; }
        return true;
      }

      if (window.innerWidth > 768) {
        window.addEventListener('wheel', function(e) {
          if (handleDelta(e.deltaY)) e.preventDefault();
        }, { passive: false });
      }

      renderPipeline(0);

      // Mobile
      if (isMobile) {
        var mobileEl = document.getElementById('lp-mobile');
        var mSvg = document.getElementById('lpm-svg');
        var mPath = document.getElementById('lpm-route');
        var mCard = document.getElementById('lpm-prospect');
        var mParticles = [document.getElementById('lpm-p1'), document.getElementById('lpm-p2')];
        var mNodes = mobileEl ? mobileEl.querySelectorAll('.lpm-n') : [];
        var mCalSlots = mobileEl ? mobileEl.querySelectorAll('.lpm-cal-slot') : [];
        if (mobileEl && mPath && mCard) {
          var mPathLen = mPath.getTotalLength();
          var canvasEl = mobileEl.querySelector('.lpm-canvas');
          function scaleCanvas() {
            var vw = mobileEl.offsetWidth;
            var scale = vw / 360;
            canvasEl.style.height = (850 * scale) + 'px';
            canvasEl.style.transform = 'scale(' + scale + ')';
            canvasEl.style.transformOrigin = 'left top';
          }
          scaleCanvas();
          window.addEventListener('resize', scaleCanvas);

          var mCurrentProgress = 0;
          var mCalEl = mobileEl.querySelector('.lpm-cal');
          var mCascadeStarted = false, mCascadeTimers = [], mLateSlots = [];
          mCalSlots.forEach(function(s) { if (s.getAttribute('data-fill') === 'late') mLateSlots.push(s); });

          var mPointCache = [], mCacheSteps = 300;
          for (var ci = 0; ci <= mCacheSteps; ci++) mPointCache.push(mPath.getPointAtLength(ci / mCacheSteps * mPathLen));
          function mGetPoint(fraction) {
            var f = Math.min(1, Math.max(0, fraction)) * mCacheSteps;
            var lo = Math.floor(f), hi = Math.min(mCacheSteps, lo + 1), t = f - lo;
            var a = mPointCache[lo], b = mPointCache[hi];
            return { x: a.x + (b.x - a.x) * t, y: a.y + (b.y - a.y) * t };
          }

          function renderMobile(p) {
            var pathStart = 0.05, mp = pathStart + p * (1 - pathStart), pt = mGetPoint(mp);
            var arrivalStart = 0.82;
            var scaleVal = p > arrivalStart ? Math.max(0.3, 1 - (p - arrivalStart) / (1 - arrivalStart) * 0.7) : 1;
            mCard.style.transform = 'translate(' + (pt.x - 50) + 'px,' + (pt.y - 20) + 'px) scale(' + scaleVal + ')';
            var op = 1;
            if (p < 0.04) op = p / 0.04;
            else if (p > 0.90) op = Math.max(0, 1 - (p - 0.90) * 10);
            mCard.style.opacity = op;
            mParticles.forEach(function(par, i) {
              if (!par) return;
              var pFrac = Math.max(0, mp - (0.018 + i * 0.012));
              var pp = mGetPoint(pFrac);
              par.style.transform = 'translate(' + pp.x + 'px,' + pp.y + 'px)';
              par.style.opacity = p > 0.06 && p < 0.86 ? (0.45 - i * 0.15) : 0;
            });
            mNodes.forEach(function(node) {
              var nx = parseInt(node.style.left), ny = parseInt(node.style.top);
              node.classList.toggle('active', Math.hypot(pt.x - nx, pt.y - ny) < 130);
            });
            if (mCalEl) mCalEl.classList.toggle('lpm-cal-arrived', p > 0.85);
            if (p > 0.85 && !mCascadeStarted) {
              mCascadeStarted = true;
              var sorted = mLateSlots.slice().sort(function(a, b) { return Array.from(a.parentNode.children).indexOf(a) - Array.from(b.parentNode.children).indexOf(b); });
              mCascadeTimers = [];
              sorted.forEach(function(slot, i) { mCascadeTimers.push(setTimeout(function() { slot.classList.add('filled'); }, 1000 * (i + 1))); });
            }
            if (p < 0.75 && mCascadeStarted) {
              mCascadeStarted = false;
              mCascadeTimers.forEach(function(t) { clearTimeout(t); });
              mLateSlots.forEach(function(slot) { slot.classList.remove('filled'); });
            }
          }

          function onScroll() {
            var rect = section.getBoundingClientRect(), winH = window.innerHeight;
            var totalTravel = rect.height + winH;
            var scrolled = winH - rect.top;
            var rawP = Math.max(0, Math.min(1, scrolled / totalTravel));
            var sH = rect.height;
            var start = (winH * 0.6) / totalTravel, end = (sH + winH * 0.3) / totalTravel;
            var mapped = Math.max(0, Math.min(1, (rawP - start) / (end - start)));
            var diff = mapped - mCurrentProgress;
            mCurrentProgress += diff * (Math.abs(diff) > 0.08 ? 0.18 : 0.12);
            renderMobile(mCurrentProgress);
            requestAnimationFrame(onScroll);
          }
          requestAnimationFrame(onScroll);
          renderMobile(0);
        }
      }
    })();
  </script>
