        for (var i = 0; i <= 6; i++) anchors.push({ x: i / 6 * hw, y: hh });
        for (var i = 1; i <= 4; i++) anchors.push({ x: 0, y: i / 5 * hh });
        for (var i = 1; i <= 4; i++) anchors.push({ x: hw, y: i / 5 * hh });
