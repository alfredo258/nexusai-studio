        }
      }
      function onMove(e) {
        if (!active) return;
        var t = e.touches ? e.touches[0] : e, dx = t.clientX - smx, dy = t.clientY - smy, dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 80) { dx = dx * 80 / dist; dy = dy * 80 / dist; }
        active.curX = scx + dx; active.curY = scy + dy;
