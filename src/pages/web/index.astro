---
import Layout from '../../layouts/Layout.astro';
import GridBackground from '../../components/GridBackground.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import Hero from '../../components/Hero.astro';
import Stats from '../../components/Stats.astro';
import Services from '../../components/Services.astro';
import Process from '../../components/Process.astro';
import LivingPipeline from '../../components/LivingPipeline.astro';
import Verticals from '../../components/Verticals.astro';
import Testimonials from '../../components/Testimonials.astro';
import Clients from '../../components/Clients.astro';
import SocialProof from '../../components/SocialProof.astro';
import Calendar from '../../components/Calendar.astro';
import Footer from '../../components/Footer.astro';
import JsonLd from '../../components/JsonLd.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "The Outbound Force",
  "description": "Implementamos un sistema de prospección B2B predecible para empresas. LinkedIn, Email Marketing, Meta Ads y Google Ads. +500 reuniones agendadas.",
  "url": "https://theoutboundforce.com",
  "areaServed": ["Argentina", "LATAM", "España", "USA"],
  "serviceType": ["Prospección B2B", "Generación de Leads", "Email Marketing", "LinkedIn Outreach", "Meta Ads", "Google Ads", "Landing Pages"],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "5"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Rosario",
    "addressRegion": "Santa Fe",
    "addressCountry": "Argentina"
  }
};
---

<Layout
  title="The Outbound Force — Prospección B2B que llena tu agenda de reuniones"
  description="Implementamos un sistema de prospección B2B predecible para empresas. LinkedIn, Email Marketing, Meta Ads y Google Ads. +500 reuniones agendadas. Agendá tu llamada gratis."
  canonical="/"
>
  <JsonLd data={serviceSchema} />
  <!-- ═══ NAV MULTI-PAGE ═══ -->
  <nav id="navbar">
    <div class="nav-inner">
      <a href="/web/" class="nav-logo">The Outbound <span>Force</span></a>
      <div class="nav-links" id="navLinks">
        <a href="/web/" class="nav-active">Inicio</a>
        <a href="/web/outbound">Outbound</a>
        <a href="/web/desarrollo-web">Desarrollo Web</a>
        <a href="/web/faq">FAQ</a>
      <a href="/web/contacto">Contacto</a>
        <ThemeToggle />
        <a
          href="https://calendar.app.google/Jxg7er6LkiL6tGEw6"
          class="nav-cta magnetic-btn"
          rel="noopener"
          target="_blank"
        >Agendar Reunión</a>
      </div>
      <button aria-label="Menú" class="menu-toggle" id="menuToggle">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main id="main-content" tabindex="-1">
    <Hero />

    <!-- Mobile social proof cards with spider-web (identical to original) -->
    <div class="mobile-proof" aria-hidden="true">
      <svg class="mp-web" viewBox="0 0 350 200" preserveAspectRatio="xMidYMid slice">
        <line x1="175" y1="100" x2="0" y2="0" stroke="rgba(109,40,217,0.35)" stroke-width="1.2"/>
        <line x1="175" y1="100" x2="175" y2="-10" stroke="rgba(109,40,217,0.32)" stroke-width="1.1"/>
        <line x1="175" y1="100" x2="350" y2="0" stroke="rgba(109,40,217,0.35)" stroke-width="1.2"/>
        <line x1="175" y1="100" x2="360" y2="60" stroke="rgba(109,40,217,0.28)" stroke-width="1"/>
        <line x1="175" y1="100" x2="360" y2="100" stroke="rgba(109,40,217,0.32)" stroke-width="1.1"/>
        <line x1="175" y1="100" x2="360" y2="145" stroke="rgba(109,40,217,0.28)" stroke-width="1"/>
        <line x1="175" y1="100" x2="350" y2="200" stroke="rgba(109,40,217,0.35)" stroke-width="1.2"/>
        <line x1="175" y1="100" x2="175" y2="210" stroke="rgba(109,40,217,0.32)" stroke-width="1.1"/>
        <line x1="175" y1="100" x2="0" y2="200" stroke="rgba(109,40,217,0.35)" stroke-width="1.2"/>
        <line x1="175" y1="100" x2="-10" y2="145" stroke="rgba(109,40,217,0.28)" stroke-width="1"/>
        <line x1="175" y1="100" x2="-10" y2="100" stroke="rgba(109,40,217,0.32)" stroke-width="1.1"/>
        <line x1="175" y1="100" x2="-10" y2="60" stroke="rgba(109,40,217,0.28)" stroke-width="1"/>
        <line x1="175" y1="100" x2="70" y2="-5" stroke="rgba(109,40,217,0.20)" stroke-width="0.8"/>
        <line x1="175" y1="100" x2="280" y2="-5" stroke="rgba(109,40,217,0.20)" stroke-width="0.8"/>
        <line x1="175" y1="100" x2="360" y2="30" stroke="rgba(109,40,217,0.18)" stroke-width="0.7"/>
        <line x1="175" y1="100" x2="360" y2="172" stroke="rgba(109,40,217,0.18)" stroke-width="0.7"/>
        <line x1="175" y1="100" x2="280" y2="208" stroke="rgba(109,40,217,0.20)" stroke-width="0.8"/>
        <line x1="175" y1="100" x2="70" y2="208" stroke="rgba(109,40,217,0.20)" stroke-width="0.8"/>
        <line x1="175" y1="100" x2="-10" y2="172" stroke="rgba(109,40,217,0.18)" stroke-width="0.7"/>
        <line x1="175" y1="100" x2="-10" y2="30" stroke="rgba(109,40,217,0.18)" stroke-width="0.7"/>
        <line x1="175" y1="100" x2="125" y2="-8" stroke="rgba(109,40,217,0.13)" stroke-width="0.55"/>
        <line x1="175" y1="100" x2="230" y2="-8" stroke="rgba(109,40,217,0.13)" stroke-width="0.55"/>
        <line x1="175" y1="100" x2="125" y2="210" stroke="rgba(109,40,217,0.13)" stroke-width="0.55"/>
        <line x1="175" y1="100" x2="230" y2="210" stroke="rgba(109,40,217,0.13)" stroke-width="0.55"/>
        <path d="M175,84 Q187,81 193,88 Q199,97 192,106 Q185,114 176,115 Q165,116 159,108 Q153,99 158,91 Q163,84 175,84Z" fill="none" stroke="rgba(109,40,217,0.38)" stroke-width="0.9"/>
        <path d="M175,70 Q203,65 218,77 Q233,91 227,110 Q220,130 198,135 Q175,139 153,133 Q131,125 127,104 Q123,82 140,72 Q154,65 175,70Z" fill="none" stroke="rgba(109,40,217,0.32)" stroke-width="0.85"/>
        <path d="M175,55 Q218,48 244,65 Q270,84 266,108 Q262,135 236,150 Q208,162 175,160 Q140,158 115,143 Q90,126 88,100 Q86,72 112,58 Q138,46 175,55Z" fill="none" stroke="rgba(109,40,217,0.26)" stroke-width="0.8"/>
        <path d="M175,40 Q232,32 266,52 Q302,74 300,106 Q298,142 268,162 Q236,180 175,178 Q114,176 82,160 Q48,142 46,106 Q44,68 76,50 Q110,32 175,40Z" fill="none" stroke="rgba(109,40,217,0.22)" stroke-width="0.75"/>
        <path d="M175,26 Q246,16 290,42 Q336,70 334,106 Q332,148 292,175 Q252,198 175,196 Q98,194 56,173 Q12,150 10,106 Q8,58 50,34 Q96,12 175,26Z" fill="none" stroke="rgba(109,40,217,0.17)" stroke-width="0.7"/>
        <path d="M175,14 Q258,2 310,32 Q364,64 362,106 Q360,154 314,184 Q264,210 175,208 Q84,206 34,182 Q-16,156 -14,106 Q-12,52 36,26 Q88,0 175,14Z" fill="none" stroke="rgba(109,40,217,0.12)" stroke-width="0.6"/>
        <path d="M175,4 Q270,-6 328,24 Q386,56 384,106 Q382,162 330,194 Q274,222 175,220 Q74,218 20,192 Q-34,164 -32,106 Q-30,44 22,18 Q78,-8 175,4Z" fill="none" stroke="rgba(109,40,217,0.08)" stroke-width="0.5"/>
        <path d="M158,86 Q162,78 172,82" fill="none" stroke="rgba(109,40,217,0.22)" stroke-width="0.5"/>
        <path d="M184,84 Q191,78 197,86" fill="none" stroke="rgba(109,40,217,0.22)" stroke-width="0.5"/>
        <path d="M165,110 Q172,116 182,112" fill="none" stroke="rgba(109,40,217,0.22)" stroke-width="0.5"/>
        <circle cx="175" cy="100" r="2.5" fill="rgba(109,40,217,0.30)"/>
        <circle cx="175" cy="100" r="5.5" fill="none" stroke="rgba(109,40,217,0.15)" stroke-width="0.5"/>
        <circle cx="193" cy="88" r="1.5" fill="rgba(109,40,217,0.22)"/>
        <circle cx="158" cy="91" r="1.3" fill="rgba(109,40,217,0.20)"/>
        <circle cx="159" cy="108" r="1.5" fill="rgba(109,40,217,0.22)"/>
        <circle cx="192" cy="106" r="1.3" fill="rgba(109,40,217,0.20)"/>
        <circle cx="218" cy="77" r="1.3" fill="rgba(109,40,217,0.16)"/>
        <circle cx="127" cy="104" r="1.3" fill="rgba(109,40,217,0.16)"/>
        <circle cx="244" cy="65" r="1.1" fill="rgba(109,40,217,0.12)"/>
        <circle cx="115" cy="143" r="1.1" fill="rgba(109,40,217,0.12)"/>
      </svg>
      <div class="mp-card" style="left:5%;top:15%">
        <div class="mp-icon mp-green"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg></div>
        <div><div class="mp-title">Reunión confirmada</div><div class="mp-sub">Miércoles 10:00 AM</div></div>
      </div>
      <div class="mp-card" style="right:3%;top:8%">
        <div class="mp-icon mp-blue"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.064 2.064 0 110-4.128 2.064 2.064 0 010 4.128zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg></div>
        <div><div class="mp-title">Nuevo lead calificado</div><div class="mp-sub">VP Comercial · SaaS B2B</div></div>
      </div>
      <div class="mp-card" style="left:8%;top:58%">
        <div class="mp-icon mp-violet"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
        <div><div class="mp-title">+10 reuniones este mes</div><div class="mp-sub">Pipeline creciendo</div></div>
      </div>
      <div class="mp-card" style="right:6%;top:52%">
        <div class="mp-icon mp-amber"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg></div>
        <div><div class="mp-title">Propuesta aprobada</div><div class="mp-sub">Deal cerrado</div></div>
      </div>
    </div>

    <Verticals />
    <SocialProof />
    <LivingPipeline />
    <Testimonials />
    <Calendar />
  </main>
  <Footer />

  <!-- ═══ ALL SCRIPTS — Identical to original index.astro ═══ -->
  <script is:inline>
    // Scroll reveal observer
    var allR = document.querySelectorAll(".reveal,.reveal-left,.reveal-right,.reveal-scale");
    var rObs = new IntersectionObserver(function(e) {
      e.forEach(function(e) { e.isIntersecting && e.target.classList.add("active"); });
    }, { threshold: 0.08, rootMargin: "0px 0px -40px 0px" });
    allR.forEach(function(e) { rObs.observe(e); });

    // Nav scroll effect
    window.addEventListener("scroll", function() {
      document.getElementById("navbar").classList.toggle("scrolled", window.scrollY > 50);
    });

    // Mobile menu
    document.getElementById("menuToggle").addEventListener("click", function() {
      document.getElementById("navLinks").classList.toggle("open");
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(function(e) {
      e.addEventListener("click", function(t) {
        t.preventDefault();
        var n = document.querySelector(e.getAttribute("href"));
        n && (n.scrollIntoView({ behavior: "smooth", block: "start" }),
          document.getElementById("navLinks").classList.remove("open"));
      });
    });

    // Slot counter animation
    var slotCounters = document.querySelectorAll(".slot-counter");
    var slotObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.dataset.target);
        var prefix = el.dataset.prefix || "";
        var fps = 1000 / 60;
        var totalFrames = Math.round(2000 / fps);
        var frame = 0;
        var timer = setInterval(function() {
          frame++;
          var progress = 1 - Math.pow(1 - frame / totalFrames, 4);
          el.textContent = prefix + Math.round(target * progress);
          if (frame === totalFrames) clearInterval(timer);
        }, fps);
        slotObs.unobserve(el);
      });
    }, { threshold: 0.5 });
    slotCounters.forEach(function(e) { slotObs.observe(e); });

    // Parallax floating elements
    document.addEventListener("mousemove", function(e) {
      var els = document.querySelectorAll(".float-el");
      var mx = 20 * (e.clientX / window.innerWidth - 0.5);
      var my = 20 * (e.clientY / window.innerHeight - 0.5);
      els.forEach(function(el, i) {
        var factor = 0.4 * (i + 1);
        el.style.transform = "translate(" + mx * factor + "px," + my * factor + "px)";
      });
    });

    // Magnetic buttons
    document.querySelectorAll('.magnetic-btn').forEach(function(btn) {
      var strength = 0.3;
      btn.addEventListener('mousemove', function(e) {
        var rect = btn.getBoundingClientRect();
        var x = e.clientX - rect.left - rect.width / 2;
        var y = e.clientY - rect.top - rect.height / 2;
        btn.style.transform = 'translate(' + x * strength + 'px, ' + y * strength + 'px)';
      });
      btn.addEventListener('mouseleave', function() {
        btn.style.transform = 'translate(0, 0)';
        btn.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
        setTimeout(function() { btn.style.transition = ''; }, 400);
      });
      btn.addEventListener('mouseenter', function() { btn.style.transition = 'none'; });
    });

    // Mascot interactions
    document.querySelectorAll('.time-slot').forEach(function(s) {
      s.addEventListener('click', function() {
        var c = document.querySelector('.mascot-toggle');
        if (c) { c.checked = true; setTimeout(function() { c.checked = false; }, 3000); }
      });
    });
    var bubbleLink = document.querySelector('.bubble-link');
    if (bubbleLink) {
      bubbleLink.addEventListener('click', function(e) {
        var toggle = document.querySelector('.mascot-toggle');
        if (toggle && toggle.checked) {
          window.open('https://calendar.app.google/Jxg7er6LkiL6tGEw6', '_blank');
        }
        e.stopPropagation();
      });
    }
    var mascotToggle = document.querySelector('.mascot-toggle');
    if (mascotToggle) {
      mascotToggle.addEventListener('change', function() {
        if (this.checked) { setTimeout(function() { mascotToggle.checked = false; }, 3000); }
      });
    }
    if (window.innerWidth < 768) {
      var catSvg = document.querySelector('.mascot-wrap svg');
      if (catSvg) catSvg.setAttribute('viewBox', '20 70 360 240');
    }

    // Mobile proof progressive reveal
    (function() {
      if (window.innerWidth >= 768) return;
      var proof = document.querySelector('.mobile-proof');
      if (!proof) return;
      var svg = proof.querySelector('.mp-web');
      var cards = proof.querySelectorAll('.mp-card');
      if (!cards.length) return;
      var allEls = Array.from(svg.children);
      var quarters = [[], [], [], []];
      function getElQuadrants(el) {
        var pts = [];
        if (el.tagName === 'line') {
          pts.push({ x: parseFloat(el.getAttribute('x1')), y: parseFloat(el.getAttribute('y1')) });
          pts.push({ x: parseFloat(el.getAttribute('x2')), y: parseFloat(el.getAttribute('y2')) });
        } else if (el.tagName === 'circle') {
          return [(parseFloat(el.getAttribute('cx')) < 175 ? 0 : 1) + (parseFloat(el.getAttribute('cy')) < 100 ? 0 : 2)];
        } else if (el.tagName === 'path') {
          var nums = (el.getAttribute('d') || '').match(/-?[\d.]+/g);
          if (nums) for (var i = 0; i < nums.length - 1; i += 2) pts.push({ x: parseFloat(nums[i]), y: parseFloat(nums[i + 1]) });
        }
        var qs = {};
        pts.forEach(function(p) { qs[(p.x < 175 ? 0 : 1) + (p.y < 100 ? 0 : 2)] = true; });
        var result = Object.keys(qs).map(Number);
        return result.length ? result : [0];
      }
      allEls.forEach(function(el) { if (el.tagName === 'defs') return; getElQuadrants(el).forEach(function(q) { quarters[q].push(el); }); });
      allEls.forEach(function(el) { if (el.tagName === 'defs') return; el.style.opacity = '0'; el.style.transition = 'opacity 0.8s cubic-bezier(0.16,1,0.3,1)'; });
      var cardToQuadrant = [0, 1, 2, 3];
      var revealedQuadrants = {};
      function revealQuarter(q) { if (revealedQuadrants[q]) return; revealedQuadrants[q] = true; quarters[q].forEach(function(el) { el.style.opacity = '1'; }); }
      var proofRect = proof.getBoundingClientRect();
      var cardData = [];
      cards.forEach(function(card, i) {
        card.style.touchAction = 'none';
        var rect = card.getBoundingClientRect();
        cardData.push({ card: card, origX: rect.left + rect.width / 2 - proofRect.left, origY: rect.top + rect.height / 2 - proofRect.top, curX: 0, curY: 0, index: i });
        cardData[i].curX = cardData[i].origX; cardData[i].curY = cardData[i].origY;
      });
      var active = null, smx = 0, smy = 0, scx = 0, scy = 0;
      proof.addEventListener('touchstart', function(e) {
        var t = e.touches[0];
        for (var i = 0; i < cardData.length; i++) {
          var r = cardData[i].card.getBoundingClientRect();
          if (t.clientX >= r.left && t.clientX <= r.right && t.clientY >= r.top && t.clientY <= r.bottom) {
            active = cardData[i]; active.card.style.zIndex = '5'; smx = t.clientX; smy = t.clientY; scx = active.curX; scy = active.curY;
            revealQuarter(cardToQuadrant[i]); e.preventDefault(); break;
          }
        }
      }, { passive: false });
      window.addEventListener('touchmove', function(e) {
        if (!active) return;
        var t = e.touches[0], dx = t.clientX - smx, dy = t.clientY - smy, dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 50) { dx = dx * 50 / dist; dy = dy * 50 / dist; }
        active.curX = scx + dx; active.curY = scy + dy;
        active.card.style.transform = 'translate(' + (active.curX - active.origX) + 'px,' + (active.curY - active.origY) + 'px)';
        e.preventDefault();
      }, { passive: false });
      window.addEventListener('touchend', function() {
        if (!active) return;
        active.card.style.zIndex = '1'; var c = active; active = null;
        var vx = 0, vy = 0;
        (function bounce() {
          var dx = c.origX - c.curX, dy = c.origY - c.curY;
          vx = (vx + dx * 0.15) * 0.75; vy = (vy + dy * 0.15) * 0.75;
          c.curX += vx; c.curY += vy;
          c.card.style.transform = 'translate(' + (c.curX - c.origX) + 'px,' + (c.curY - c.origY) + 'px)';
          if (Math.abs(dx) > 0.3 || Math.abs(dy) > 0.3 || Math.abs(vx) > 0.3 || Math.abs(vy) > 0.3) requestAnimationFrame(bounce);
          else { c.curX = c.origX; c.curY = c.origY; c.card.style.transform = 'translate(0,0)'; }
        })();
      });
      var t = 0;
      (function idleFloat() {
        if (active) { requestAnimationFrame(idleFloat); return; }
        t += 0.006;
        cardData.forEach(function(d, i) {
          var offX = Math.sin(t + i * 1.7) * 4, offY = Math.cos(t * 0.6 + i * 2.1) * 3;
          d.curX = d.origX + offX; d.curY = d.origY + offY;
          d.card.style.transform = 'translate(' + offX + 'px,' + offY + 'px)';
        });
        requestAnimationFrame(idleFloat);
      })();
    })();

    // Testimonials — clone for infinite carousel
    (function() {
      var track = document.querySelector('.t-track');
      if (!track) return;
      track.querySelectorAll('.t-card').forEach(function(c) { track.appendChild(c.cloneNode(true)); });
    })();

    // Spider-web cards — Hero
    (function() {
      var isMobile = window.innerWidth < 768;
      var hero = document.querySelector('.hero');
      var cards = document.querySelectorAll('.pipe-card');
      if (!hero || !cards.length) return;
      var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;';
      hero.querySelector('.pipe-wrap').appendChild(svg);
      var heroRect = hero.getBoundingClientRect(), hw = heroRect.width, hh = heroRect.height;
      var anchors = [];
      for (var i = 0; i <= 8; i++) anchors.push({ x: i / 8 * hw, y: 0 });
      for (var i = 0; i <= 6; i++) anchors.push({ x: i / 6 * hw, y: hh });
      for (var i = 1; i <= 4; i++) anchors.push({ x: 0, y: i / 5 * hh });
      for (var i = 1; i <= 4; i++) anchors.push({ x: hw, y: i / 5 * hh });
      function makeLine(x1, y1, x2, y2, opacity, width, dash) {
        var l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        l.setAttribute('x1', x1); l.setAttribute('y1', y1); l.setAttribute('x2', x2); l.setAttribute('y2', y2);
        l.setAttribute('stroke', 'rgba(109,40,217,' + opacity + ')'); l.setAttribute('stroke-width', width);
        if (dash) l.setAttribute('stroke-dasharray', dash);
        l.setAttribute('stroke-linecap', 'round'); svg.appendChild(l); return l;
      }
      var webData = [];
      cards.forEach(function(card) {
        card.style.animation = 'none'; card.style.opacity = '1'; card.style.clipPath = 'none'; card.style.zIndex = '3'; card.style.position = 'absolute';
        if (!isMobile) { card.style.pointerEvents = 'auto'; card.style.cursor = 'grab'; card.style.userSelect = 'none'; card.style.transition = 'none'; }
        var rect = card.getBoundingClientRect();
        var cx = rect.left + rect.width / 2 - heroRect.left, cy = rect.top + rect.height / 2 - heroRect.top;
