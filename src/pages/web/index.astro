        });
        for (var i = 0; i < webData.length; i++) for (var j = i + 1; j < webData.length; j++) {
          var a = webData[i], b = webData[j];
          if (Math.sqrt(Math.pow(a.origX - b.origX, 2) + Math.pow(a.origY - b.origY, 2)) < hw * 0.6) {
            var op = (0.04 + Math.random() * 0.06).toFixed(2), el = makeLine(a.origX, a.origY, b.origX, b.origY, op, '0.6', '6,4');
            a.lines.push({ el: el, ax: b.origX, ay: b.origY, baseOp: parseFloat(op), baseW: 0.6, linked: j });
