---
import JsonLd from '../components/JsonLd.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const siteUrl = 'https://theoutboundforce.com';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "The Outbound Force",
  "url": siteUrl,
  "logo": `${siteUrl}/og-image.png`,
  "description": "Implementamos un sistema de prospección B2B predecible para empresas. LinkedIn, Email Marketing, Meta Ads y Google Ads.",
  "email": "alfredo@theoutboundforce.com",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "alfredo@theoutboundforce.com",
    "contactType": "sales",
    "availableLanguage": ["Spanish", "English"]
  },
  "sameAs": [
    "https://www.linkedin.com/company/the-outbound-force"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "The Outbound Force",
  "url": siteUrl,
  "description": description,
  "inLanguage": "es",
  "publisher": { "@type": "Organization", "name": "The Outbound Force" }
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width,initial-scale=1" name="viewport" />
    <meta name="theme-color" content="#6d28d9" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="prospección B2B, generación de leads, agencia outbound, reuniones calificadas, cold email, LinkedIn outreach, Meta Ads, Google Ads, landing pages, Argentina, LATAM" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl + "/"} />
    <meta name="author" content="The Outbound Force" />

    <!-- Open Graph -->
    <meta property="og:locale" content="es_AR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl + "/"} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Outbound Force" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts (async) -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="generator" content={Astro.generator} />

    <!-- JSON-LD -->
    <JsonLd data={orgSchema} />
    <JsonLd data={websiteSchema} />
  </head>
  <body style="touch-action:pan-y;">
    <a href="#servicios" class="skip-to-content">Saltar al contenido</a>
    <slot />
  </body>
</html>
